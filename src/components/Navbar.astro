---
import { ministries } from '../data/ministries';
---

<nav data-animate="nav" class="sticky top-0 w-full z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <div class="flex-shrink-0 flex items-center gap-3">
        <a href="/" class="flex items-center gap-3">
          <div class="bg-charcoal text-white p-2 flex flex-col justify-center items-center h-10 w-10 rounded-full">
            <span class="font-display font-bold text-lg leading-none">Cf</span>
          </div>
          <span class="font-display text-lg font-bold tracking-tight text-charcoal">Corazón de Fuego</span>
        </a>
      </div>
      <div class="hidden md:flex items-center space-x-8">
        <a data-animate="nav-link" class="text-xs font-bold tracking-widest uppercase hover:text-primary transition-colors text-charcoal" href="/">Inicio</a>
        <a data-animate="nav-link" class="text-xs font-bold tracking-widest uppercase hover:text-primary transition-colors text-charcoal" href="/#novedades">Novedades</a>
        <a data-animate="nav-link" class="text-xs font-bold tracking-widest uppercase hover:text-primary transition-colors text-charcoal" href="/devocional">Devocional</a>
        <details class="relative group [&_summary::-webkit-details-marker]:hidden">
          <summary data-animate="nav-link" class="list-none cursor-pointer text-xs font-bold tracking-widest uppercase hover:text-primary transition-colors text-charcoal inline-flex items-center gap-1">
            Ministerios
            <span class="material-symbols-outlined text-base transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="absolute left-1/2 -translate-x-1/2 mt-4 w-60 rounded-2xl border border-gray-200 bg-white shadow-xl p-2">
            <a class="block rounded-xl px-3 py-2 text-[11px] font-bold tracking-widest uppercase text-charcoal hover:bg-gray-100 hover:text-primary transition-colors" href="/ministerios">
              Ver todos
            </a>
            {
              ministries.map((ministry) => (
                <a
                  class="block rounded-xl px-3 py-2 text-[11px] font-bold tracking-widest uppercase text-charcoal hover:bg-gray-100 hover:text-primary transition-colors"
                  href={`/ministerios/${ministry.slug}`}
                >
                  {ministry.name}
                </a>
              ))
            }
          </div>
        </details>
        <a data-animate="nav-link" class="text-xs font-bold tracking-widest uppercase hover:text-primary transition-colors text-charcoal" href="/#radio">Radio</a>
        <a data-animate="nav-link" class="px-5 py-2 bg-charcoal text-white text-xs font-bold tracking-wider uppercase rounded-full hover:bg-primary transition-colors" href="/contact">Contacto</a>
      </div>
      <div class="md:hidden">
        <button
          id="mobile-menu-button"
          class="text-charcoal hover:text-primary focus:outline-none"
          aria-label="Abrir menú"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <span class="material-symbols-outlined text-3xl">menu</span>
        </button>
      </div>
    </div>
    <div
      id="mobile-menu"
      class="md:hidden overflow-hidden max-h-0 opacity-0 pointer-events-none transition-all duration-300 ease-out"
    >
      <div class="flex flex-col gap-1 border-t border-gray-100 pt-4">
        <a class="mobile-link px-2 py-2 text-xs font-bold tracking-widest uppercase text-charcoal hover:text-primary transition-colors" href="/">Inicio</a>
        <a class="mobile-link px-2 py-2 text-xs font-bold tracking-widest uppercase text-charcoal hover:text-primary transition-colors" href="/#novedades">Novedades</a>
        <a class="mobile-link px-2 py-2 text-xs font-bold tracking-widest uppercase text-charcoal hover:text-primary transition-colors" href="/devocional">Devocional</a>
        <details id="mobile-ministerios-menu" class="group [&_summary::-webkit-details-marker]:hidden">
          <summary class="list-none px-2 py-2 text-xs font-bold tracking-widest uppercase text-charcoal hover:text-primary transition-colors inline-flex items-center gap-1 cursor-pointer">
            Ministerios
            <span class="material-symbols-outlined text-base transition-transform group-open:rotate-180">expand_more</span>
          </summary>
          <div class="pl-4 pb-1 flex flex-col gap-1">
            <a class="mobile-link px-2 py-1.5 text-[11px] font-bold tracking-widest uppercase text-charcoal hover:text-primary transition-colors" href="/ministerios">Ver todos</a>
            {
              ministries.map((ministry) => (
                <a
                  class="mobile-link px-2 py-1.5 text-[11px] font-bold tracking-widest uppercase text-charcoal hover:text-primary transition-colors"
                  href={`/ministerios/${ministry.slug}`}
                >
                  {ministry.name}
                </a>
              ))
            }
          </div>
        </details>
        <a class="mobile-link px-2 py-2 text-xs font-bold tracking-widest uppercase text-charcoal hover:text-primary transition-colors" href="/#radio">Radio</a>
        <a class="mobile-link mt-2 inline-flex w-fit px-5 py-2 bg-charcoal text-white text-xs font-bold tracking-wider uppercase rounded-full hover:bg-primary transition-colors" href="/contact">Contacto</a>
      </div>
    </div>
  </div>
</nav>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const mobileMinistriesMenu = document.getElementById('mobile-ministerios-menu') as HTMLDetailsElement | null;

  if (button && menu) {
    const closedClasses = ['max-h-0', 'opacity-0', 'pointer-events-none'];
    const openClasses = ['max-h-80', 'opacity-100', 'pointer-events-auto', 'pb-5'];

    const toggleMenu = () => {
      const isExpanded = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', String(!isExpanded));
      if (isExpanded) {
        menu.classList.remove(...openClasses);
        menu.classList.add(...closedClasses);
        if (mobileMinistriesMenu) mobileMinistriesMenu.open = false;
      } else {
        menu.classList.remove(...closedClasses);
        menu.classList.add(...openClasses);
      }
    };

    button.addEventListener('click', toggleMenu);
    menu.querySelectorAll('.mobile-link').forEach((link) => {
      link.addEventListener('click', () => {
        button.setAttribute('aria-expanded', 'false');
        menu.classList.remove(...openClasses);
        menu.classList.add(...closedClasses);
        if (mobileMinistriesMenu) mobileMinistriesMenu.open = false;
      });
    });
  }
</script>
