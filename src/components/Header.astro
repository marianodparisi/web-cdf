---
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-black/90 backdrop-blur-md border-b border-white/10">
  <nav class="container mx-auto px-4 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="text-white font-display font-bold text-xl lg:text-2xl tracking-wide hover:text-primary-400 transition-colors duration-300">
          CORAZÓN DE FUEGO
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center space-x-8">
        <a href="/" class="text-white hover:text-primary-400 transition-colors duration-300 font-medium">
          Inicio
        </a>
        
        <!-- Ministerios Dropdown -->
        <div class="relative group">
          <button class="text-white hover:text-primary-400 transition-colors duration-300 font-medium flex items-center space-x-1">
            <span>Ministerios</span>
            <svg class="w-4 h-4 transform group-hover:rotate-180 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          
          <div class="absolute top-full left-0 mt-2 w-48 bg-white rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
            <div class="py-2">
              <a href="#" class="block px-4 py-2 text-gray-800 hover:bg-primary-50 hover:text-primary-600 transition-colors duration-200">Ministerio de Alabanza</a>
              <a href="#" class="block px-4 py-2 text-gray-800 hover:bg-primary-50 hover:text-primary-600 transition-colors duration-200">Ministerio Juvenil</a>
              <a href="#" class="block px-4 py-2 text-gray-800 hover:bg-primary-50 hover:text-primary-600 transition-colors duration-200">Ministerio Infantil</a>
              <a href="#" class="block px-4 py-2 text-gray-800 hover:bg-primary-50 hover:text-primary-600 transition-colors duration-200">Ministerio de Intercesión</a>
            </div>
          </div>
        </div>

        <a href="/nosotros" class="text-white hover:text-primary-400 transition-colors duration-300 font-medium">
          Nosotros
        </a>
        <a href="/contacto" class="text-white hover:text-primary-400 transition-colors duration-300 font-medium">
          Contacto
        </a>
        
        <!-- CTA Button -->
        <a href="/visitanos" class="bg-gradient-to-r from-primary-600 to-secondary-500 text-white px-6 py-2 rounded-full font-medium hover:from-primary-700 hover:to-secondary-600 transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-xl">
          Visítanos
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden text-white p-2">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="lg:hidden hidden">
      <div class="px-2 pt-2 pb-3 space-y-1 bg-black/95 rounded-lg mt-2">
        <a href="/" class="block px-3 py-2 text-white hover:text-primary-400 transition-colors duration-300">Inicio</a>
        <a href="/ministerios" class="block px-3 py-2 text-white hover:text-primary-400 transition-colors duration-300">Ministerios</a>
        <a href="/nosotros" class="block px-3 py-2 text-white hover:text-primary-400 transition-colors duration-300">Nosotros</a>
        <a href="/contacto" class="block px-3 py-2 text-white hover:text-primary-400 transition-colors duration-300">Contacto</a>
        <a href="/visitanos" class="block px-3 py-2 bg-gradient-to-r from-primary-600 to-secondary-500 text-white rounded-lg text-center mt-4">Visítanos</a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Header scroll effect
  window.addEventListener('scroll', () => {
    const header = document.getElementById('header');
    if (window.scrollY > 50) {
      header?.classList.add('bg-black/95');
      header?.classList.remove('bg-black/90');
    } else {
      header?.classList.add('bg-black/90');
      header?.classList.remove('bg-black/95');
    }
  });
</script>