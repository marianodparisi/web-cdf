---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="https://images.pexels.com/photos/8170190/pexels-photo-8170190.jpeg" 
      alt="Congregación adorando en la iglesia" 
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/40 to-black/70"></div>
    <div class="absolute inset-0 bg-hero-pattern"></div>
  </div>

  <!-- Animated Background Elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-2 h-2 bg-accent-400 rounded-full animate-pulse opacity-60"></div>
    <div class="absolute top-3/4 right-1/4 w-1 h-1 bg-primary-300 rounded-full animate-pulse opacity-40 animation-delay-1000"></div>
    <div class="absolute top-1/2 right-1/3 w-1.5 h-1.5 bg-secondary-400 rounded-full animate-pulse opacity-50 animation-delay-2000"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-6xl mx-auto">
    <!-- Main Heading -->
    <div class="mb-8">
      <h1 class="text-6xl md:text-8xl lg:text-9xl font-light text-white leading-none tracking-wider mb-4">
        Iglesia
      </h1>
      <h2 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold bg-gradient-to-r from-primary-400 via-secondary-400 to-accent-400 bg-clip-text text-transparent leading-tight mb-8">
        Corazón de Fuego
      </h2>
    </div>

    <!-- Subtitle -->
    <div class="mb-12">
      <h3 class="text-2xl md:text-3xl lg:text-4xl font-display font-semibold text-white mb-4 tracking-wide">
        JESÚS
      </h3>
      <p class="text-lg md:text-xl lg:text-2xl text-gray-200 font-light italic leading-relaxed max-w-4xl mx-auto">
        "Un nombre a todas las respuestas"
      </p>
    </div>

    <!-- Call to Action Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-16">
      <a href="/visitanos" class="bg-gradient-to-r from-primary-600 to-secondary-500 text-white px-8 py-4 rounded-full font-semibold text-lg hover:from-primary-700 hover:to-secondary-600 transition-all duration-300 transform hover:scale-105 shadow-xl hover:shadow-2xl min-w-[200px]">
        Visítanos Hoy
      </a>
      <a href="/servicios" class="border-2 border-white text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-white hover:text-gray-900 transition-all duration-300 transform hover:scale-105 min-w-[200px]">
        Ver Servicios
      </a>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </div>

  <!-- Floating Elements -->
  <div class="absolute top-20 left-10 w-20 h-20 border border-white/20 rounded-full animate-pulse hidden lg:block"></div>
  <div class="absolute bottom-20 right-10 w-16 h-16 border border-primary-400/30 rounded-full animate-pulse hidden lg:block"></div>
</section>

<style>
  .animation-delay-1000 {
    animation-delay: 1s;
  }
  
  .animation-delay-2000 {
    animation-delay: 2s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
</style>