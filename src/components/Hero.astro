<header data-animate="hero" class="relative isolate h-[calc(100svh-5rem)] overflow-hidden bg-charcoal [clip-path:inset(0)] lg:h-[calc(100vh-5rem)]">
  <div class="fixed inset-x-0 top-20 z-0 h-[calc(100svh-5rem)] lg:h-[calc(100vh-5rem)]">
    <video
      class="block h-full w-full object-cover object-center"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
    >
      <source src="/hero-v1-compressed.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/30"></div>
  </div>

  <div class="relative z-10 mx-auto flex h-[calc(100svh-5rem)] max-w-7xl items-center justify-center px-5 py-0 text-center sm:px-6 lg:h-[calc(100vh-5rem)] lg:px-8">
    <div class="w-full space-y-4 sm:space-y-5">
      <p
        data-animate="hero-late"
        class="text-primary text-[11px] font-semibold uppercase tracking-[0.24em] sm:text-xs"
      >
        iglesia cristiana
      </p>
      <h1
        data-animate="hero-item"
        class="font-display text-4xl font-semibold leading-tight tracking-tight text-white sm:text-5xl md:text-6xl"
        style="font-family: 'Inter', sans-serif;"
      >
        CORAZÓN DE FUEGO
      </h1>
      <p data-animate="hero-late" class="text-sm font-medium text-white/85 sm:text-base">
        Horario de Reuniones: Viernes 20 hs · Sábados 20 hs · Domingos 9:30 y 11:00 hs
      </p>
    </div>
  </div>
</header>
