<header data-animate="hero" class="relative h-[calc(100svh-5rem)] lg:h-[calc(100vh-5rem)] overflow-hidden bg-charcoal">
  <div data-animate="hero-media" class="absolute -inset-[2px]">
    <video
      class="block h-full w-full object-cover object-center"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="https://lh3.googleusercontent.com/aida-public/AB6AXuABKKBxUJ2mqPFeGJ2Cot4c33KW7awVH6CaBVA__bCejl6vYUaC-h_tlbKYls3chQApZyP6sb5rEhn5cvwVHMWsRp3g5Qic1JSEGdfShnVaYJuWGAPh2bs1fzuNbnOUukNXtgllMgx74T7Hk-N-8TQSW5m05WtINYNqOP0YaDqteJvWPaQdeagYQ9yF7NlVrKzI1baksu-mlkJbVcd8p0lwZohP26mlXFXYkiZrEXycUBODmkMq5K3i6cNW-fJEySPWpZ_AbK_DjUU"
    >
      <source src="/hero.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/80 via-charcoal/55 to-charcoal/40"></div>
  </div>

  <div class="relative z-10 mx-auto flex h-[calc(100svh-5rem)] lg:h-[calc(100vh-5rem)] max-w-7xl items-center justify-center px-5 sm:px-6 lg:px-8 py-0">
    <div class="w-full text-center space-y-4 sm:space-y-5">
      <p
        data-animate="hero-late"
        class="text-primary text-[11px] sm:text-xs font-semibold tracking-[0.24em] uppercase"
      >
        iglesia cristiana
      </p>
      <h1 data-animate="hero-item" class="font-body font-semibold text-4xl sm:text-5xl md:text-6xl text-white leading-tight tracking-tight lowercase">
        corazon de fuego
      </h1>
      <p data-animate="hero-late" class="text-white/85 text-sm sm:text-base font-medium">
        horario de reuniones: miercoles y viernes 20:00 hs · domingos 10:00 y 18:00 hs
      </p>
    </div>
  </div>
</header>
