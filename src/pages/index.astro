---
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Navbar from '../components/Navbar.astro';
import { devotionalPosts } from '../data/devotionals';
import { ministries } from '../data/ministries';
import BaseLayout from '../layouts/BaseLayout.astro';

const logoSlugs = new Set(['gold', 'kids', 'arde']);
const currentDevotionalPost = devotionalPosts[0];
const seriesPlaylistUrl = 'https://www.youtube.com/@Coraz%C3%B3ndeFuego/playlists';
const sermonSeries = [
  {
    title: 'Éxodo',
    subtitle: 'El camino hacia la libertad',
    label: 'Serie actual',
    image: '/series/exododesktop.jpg',
    mobileImage: '/series/exodomobile.jpg',
    href: 'https://www.youtube.com/playlist?list=PLbq3XgHcmjEtwhYdGCqO8PqbFY7EMFI5p',
    description:
      'Un recorrido por el libro de Éxodo para ver la fidelidad de Dios, la libertad y el camino hacia su propósito.',
  },
  {
    title: 'Sanados',
    subtitle: 'Restauración para el corazón',
    label: 'Serie anterior',
    image: '/series/seriesanados.jpg',
    href: 'https://www.youtube.com/playlist?list=PLbq3XgHcmjEv4unRsnKoJVVnt9yLDdv4T',
    description: 'Una serie para recibir sanidad, libertad y restauración en Jesús.',
  },
  {
    title: 'Descanso',
    subtitle: 'Serie febrero 2026',
    label: 'Serie anterior',
    image: '/series/seriedescanso.jpg',
    href: 'https://www.youtube.com/playlist?list=PLbq3XgHcmjEuy20aDEPjbTu6MUZhOCUqG',
    description: 'Una serie para volver al ritmo de Dios y aprender a descansar en su presencia.',
  },
  {
    title: 'Pertenecer',
    subtitle: 'Una casa, una familia, un propósito',
    label: 'Serie anterior',
    image: '/series/seriepertenecer.jpg',
    href: 'https://www.youtube.com/playlist?list=PLbq3XgHcmjEt1a2mr2d-g7-z6tzo7C-HP',
    description: 'Una serie sobre identidad, familia espiritual y el llamado a caminar juntos.',
  },
];
const [currentSeries, ...recentSeries] = sermonSeries;
const getYouTubeEmbedUrl = (videoUrl?: string) => {
  if (!videoUrl) return null;
  try {
    const url = new URL(videoUrl);
    const idFromPath = url.pathname.startsWith('/live/') ? url.pathname.split('/live/')[1] : null;
    const idFromQuery = url.searchParams.get('v');
    const videoId = idFromQuery || idFromPath;
    return videoId ? `https://www.youtube.com/embed/${videoId}` : videoUrl;
  } catch {
    return videoUrl;
  }
};
const currentDevotionalEmbedUrl = getYouTubeEmbedUrl(currentDevotionalPost?.videoUrl);
---

<BaseLayout>
  <Navbar />
  <Hero />

  <section data-animate="reveal" class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-[1.05fr_0.95fr] md:items-center md:gap-14">
        <div>
          <p class="mb-3 text-xs font-bold uppercase tracking-[0.22em] text-primary">Quiénes somos</p>
          <h2 class="font-display text-4xl font-semibold leading-[1.05] tracking-tight text-charcoal sm:text-5xl lg:text-6xl">
            Existimos para ministrar al Señor y encender una generación.
          </h2>
        </div>
        <div>
          <p class="max-w-2xl text-base leading-relaxed text-gray-600 sm:text-lg">
            Iglesia Corazón de Fuego es una casa de adoración, oración y formación. Nos reunimos para darle a Dios gratitud y alabanza, afirmar quién es Él, interceder por lo que desea hacer y caminar como familia en el propósito que nos confió.
          </p>
          <a class="mt-8 inline-flex items-center gap-2 border-b border-charcoal pb-1 text-xs font-bold uppercase tracking-widest text-charcoal transition-colors hover:border-primary hover:text-primary" href="/nosotros">
            Conocé más de nosotros
            <span class="material-symbols-outlined text-sm">arrow_outward</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="min-h-screen bg-[#101010] py-14 text-white md:py-16">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="mb-8 md:mb-10">
        <div>
          <p class="mb-3 text-xs font-bold uppercase tracking-[0.24em] text-primary">Series</p>
          <h2 class="font-display text-4xl font-semibold tracking-tight text-white sm:text-5xl md:text-6xl">Serie actual</h2>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3 lg:gap-8">
        <a
          data-animate="card"
          href={currentSeries.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Ver serie ${currentSeries.title}`}
          class="group relative block h-[440px] overflow-hidden rounded-[2.5rem] border-8 border-white bg-black md:h-[520px] lg:col-span-2"
        >
          <picture class="absolute inset-x-0 top-0 flex h-[70%] w-full items-center justify-center overflow-hidden rounded-b-[2rem]">
            {currentSeries.mobileImage && <source media="(max-width: 767px)" srcset={currentSeries.mobileImage} />}
            <img
              src={currentSeries.image}
              alt={`Serie ${currentSeries.title}`}
              class="h-full w-full object-cover object-center opacity-85 transition-transform duration-700 group-hover:scale-105"
            />
          </picture>
          <div class="absolute inset-x-0 top-0 h-[70%] bg-gradient-to-t from-black/55 via-black/10 to-black/5"></div>
          <div class="absolute inset-x-0 bottom-0 z-10 flex h-[30%] flex-col justify-center bg-white p-6 sm:p-8 md:p-10">
            <div class="flex max-w-2xl flex-col gap-3">
              <span class="inline-flex w-fit rounded-full bg-charcoal px-3 py-1 text-[10px] font-bold uppercase tracking-[0.2em] text-white">
                {currentSeries.label}
              </span>
              <p class="line-clamp-2 max-w-xl text-sm leading-relaxed text-charcoal/75 sm:text-base">{currentSeries.description}</p>
            </div>
          </div>
        </a>

        <aside data-animate="card" class="flex flex-col">
          <div class="mb-5 flex items-center justify-between">
            <h3 class="text-lg font-bold tracking-tight text-white">Series anteriores</h3>
          </div>
          <div class="flex flex-col gap-4">
            {
              recentSeries.slice(0, 3).map((series) => (
                <a
                  href={series.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group grid grid-cols-[6rem_1fr] gap-4 rounded-lg border border-white/10 bg-white/[0.04] p-3 transition duration-300 hover:-translate-y-1 hover:border-primary/50 hover:bg-white/[0.07]"
                >
                  <div class="h-24 overflow-hidden rounded bg-black">
                    <img
                      src={series.image}
                      alt={`Serie ${series.title}`}
                      class="h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-110"
                    />
                  </div>
                  <div class="flex min-w-0 flex-col justify-center">
                    <span class="mb-1 text-[10px] font-bold uppercase tracking-[0.2em] text-white/45">{series.label}</span>
                    <h4 class="font-display text-lg font-semibold leading-tight text-white transition-colors group-hover:text-primary">{series.title}</h4>
                    <p class="mt-1 line-clamp-2 text-sm leading-relaxed text-white/55">{series.subtitle}</p>
                  </div>
                </a>
              ))
            }
          </div>
          <a
            href={seriesPlaylistUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group mt-7 inline-flex w-fit items-center gap-2 text-xs font-bold uppercase tracking-widest text-primary transition-all hover:gap-4"
          >
            Ver todas las series
            <span class="material-symbols-outlined text-base">arrow_forward</span>
          </a>
        </aside>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="py-14 md:py-12 bg-white" id="novedades">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-8 md:mb-10">
        <div>
          <h2 class="font-display text-4xl sm:text-5xl md:text-6xl text-charcoal mb-2">Anuncios</h2>
          <p class="text-gray-500 max-w-md">Entérate de lo que está sucediendo en nuestra casa.</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-8">
        <a
          data-animate="card"
          href="/ministerios/gold"
          aria-label="Ver más sobre Encuentro GOLD"
          class="md:col-span-2 relative block w-full h-[300px] sm:h-[360px] md:h-[450px] rounded-2xl md:rounded-3xl overflow-hidden shadow-lg group"
        >
          <img alt="Anuncio GOLD" class="absolute inset-0 h-full w-full object-cover object-top transition-transform duration-700 group-hover:scale-[1.02]" src="/ministries/gold/goldanuncio.jpg" />
          <div class="absolute inset-0 bg-gradient-to-t from-charcoal/90 via-charcoal/20 to-transparent flex flex-col justify-end p-6 sm:p-8 md:p-10">
            <span class="bg-primary text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider w-fit mb-3">Destacado</span>
            <h3 class="font-display text-2xl sm:text-3xl md:text-4xl text-white leading-tight mb-2">
              Encuentro GOLD
            </h3>
            <p class="text-gray-200 text-sm md:text-base max-w-lg mb-4 md:mb-6 font-light">
              Un tiempo especial para compartir palabra, compañerismo y crecimiento.
            </p>
            <div>
              <span class="hidden md:inline-flex items-center gap-2 text-white border-b border-white/50 pb-1 text-sm font-bold tracking-wider transition-colors group-hover:border-primary group-hover:text-primary">
                Ver más
              </span>
            </div>
          </div>
        </a>
        <div class="flex flex-col gap-5 md:gap-8 h-auto md:h-[450px]">
          <a data-animate="card" href="/ministerios/arde" class="relative min-h-[205px] md:min-h-0 flex-1 rounded-2xl md:rounded-3xl overflow-hidden shadow-md group bg-charcoal">
            <img alt="Campamento ARDE" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" src="/ministries/arde/campaarde.jpg" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-5 sm:p-6 z-10">
              <span class="inline-flex rounded-full bg-primary px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold mb-3">Campa ARDE</span>
              <h3 class="font-display text-2xl text-white mb-2">Campamento ARDE</h3>
              <p class="text-white/80 text-sm">Una experiencia para adolescentes con amigos, palabra y dias que no se olvidan facil.</p>
            </div>
          </a>
          <a data-animate="card" href="/ministerios/kids" class="relative min-h-[205px] md:min-h-0 flex-1 rounded-2xl md:rounded-3xl overflow-hidden shadow-md group bg-charcoal text-white">
            <img alt="Campa Kids" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" src="/ministries/kids/campakids.jpg" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/15 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-5 sm:p-6 z-10">
              <span class="inline-flex rounded-full bg-primary px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold mb-3">Campa Kids</span>
              <h3 class="font-display text-2xl text-white mb-2">Campamento Kids</h3>
              <p class="text-white/80 text-sm">Una aventura para que los chicos aprendan, jueguen y vivan la fe con alegria.</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="py-14 md:py-16 bg-white" id="devocional">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-8 md:mb-10">
        <div>
          <h2 class="font-display text-4xl sm:text-5xl md:text-6xl text-charcoal mb-2">Devocional Actual</h2>
        </div>
      </div>
      {currentDevotionalPost && (
        <a href="/devocional" data-animate="card" class="group grid cursor-pointer grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-6 md:gap-8 items-stretch rounded-3xl border border-gray-200 bg-gray-50 p-5 sm:p-6 md:p-8 transition-colors hover:border-primary/50">
          <div class="flex flex-col justify-center">
            <div class="flex flex-wrap items-center gap-2">
              <span class="inline-flex rounded-full bg-gray-100 px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold">{currentDevotionalPost.weekLabel}</span>
              <span class="inline-flex rounded-full bg-primary px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold">Actual</span>
            </div>
            <h3 class="font-display text-3xl md:text-4xl text-charcoal mt-4 transition-colors group-hover:text-primary">{currentDevotionalPost.title}</h3>
            <p class="text-gray-600 text-sm sm:text-base mt-4 leading-relaxed">{currentDevotionalPost.excerpt}</p>
            <span class="mt-6 inline-flex h-10 w-10 items-center justify-center rounded-full border border-charcoal/20 text-charcoal transition duration-300 ease-out group-hover:-translate-y-1 group-hover:rotate-[-30deg] group-hover:border-primary group-hover:text-primary">
              <span class="material-symbols-outlined text-xl">arrow_forward</span>
            </span>
          </div>

          <div class="relative overflow-hidden rounded-2xl bg-charcoal shadow-sm lg:max-h-[320px]">
            {currentDevotionalEmbedUrl ? (
              <iframe
                class="pointer-events-none min-h-[230px] w-full aspect-video lg:h-full lg:aspect-auto"
                src={currentDevotionalEmbedUrl}
                title={currentDevotionalPost.title}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            ) : (
              <div class="block h-full min-h-[210px]">
                <img
                  src={currentDevotionalPost.image}
                  alt={currentDevotionalPost.title}
                  class="h-full w-full object-cover translate-y-2 scale-105 transition-transform duration-500 group-hover:translate-y-2 group-hover:scale-110"
                />
              </div>
            )}
          </div>
        </a>
      )}
    </div>
  </section>

  <section data-animate="reveal" class="py-16 md:py-24 bg-gray-50" id="ministerios">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-10 md:mb-16">
        <div>
          <h2 class="font-display text-4xl sm:text-5xl md:text-6xl text-charcoal mb-4">Nuestro Liderazgo / Ministerios</h2>
          <p class="text-gray-500 max-w-md">Áreas donde servimos y crecemos juntos como familia.</p>
        </div>
      </div>
      <div class="flex flex-wrap justify-center gap-4 sm:gap-5 lg:gap-6">
        {
          ministries.map((ministry) => (
            <a data-animate="card" class="group flex w-[calc(50%-0.5rem)] min-w-0 max-w-[220px] flex-col items-center text-center md:w-[calc(33.333%-0.85rem)] lg:w-[calc(25%-1rem)] xl:w-[calc(16.666%-1rem)]" href={`/ministerios/${ministry.slug}`}>
              <div class={`relative overflow-hidden rounded-2xl md:rounded-[1.5rem] mb-3 md:mb-4 aspect-[4/5] sm:aspect-[3/4] w-full ${logoSlugs.has(ministry.slug) ? 'bg-white border border-gray-300 p-3' : ''}`}>
                <img
                  alt={`Ministerio ${ministry.name}`}
                  class={`w-full h-full transition duration-500 ${logoSlugs.has(ministry.slug) ? 'object-contain' : 'object-cover group-hover:scale-105'}`}
                  src={ministry.image}
                />
                <div class={`absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4 ${logoSlugs.has(ministry.slug) ? 'bg-gradient-to-t from-charcoal/45 to-transparent' : 'bg-gradient-to-t from-charcoal/80 to-transparent'}`}>
                  <span class="text-white text-xs font-bold uppercase tracking-wider">Ver ministerio</span>
                </div>
              </div>
              <h3 class="font-display text-base sm:text-lg text-charcoal group-hover:text-primary transition-colors">{ministry.name}</h3>
              <p class="text-xs text-gray-500 font-bold uppercase tracking-widest mt-1">{ministry.area}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="py-14 md:py-12 bg-white" id="radio">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="bg-charcoal rounded-2xl md:rounded-3xl p-6 sm:p-8 md:p-16 flex flex-col md:flex-row items-center justify-between relative overflow-hidden">
        <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
        <div class="flex items-center gap-4 sm:gap-6 relative z-10">
          <div class="h-20 w-20 rounded-full bg-white/10 flex items-center justify-center backdrop-blur-md">
            <span class="material-symbols-outlined text-white text-4xl">mic</span>
          </div>
          <div>
            <h2 class="font-display text-4xl sm:text-5xl md:text-6xl text-white mb-2">Radio Corazón</h2>
            <div class="flex items-center gap-3">
              <span class="text-gray-400 text-xs tracking-widest uppercase">La frecuencia del cielo</span>
              <div class="flex items-end gap-[3px] h-3 audio-wave">
                <span></span><span></span><span></span><span></span><span></span>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-6 md:mt-0 relative z-10 flex flex-col md:flex-row items-center gap-4 md:gap-6">
          <span class="px-4 py-1.5 bg-primary text-charcoal text-xs font-bold uppercase tracking-wider rounded-full">Próximamente</span>
          <p class="text-white/60 text-sm font-light italic text-center md:text-right">"24/7 conectados contigo."</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
