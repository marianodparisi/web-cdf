              </div>
            </div>
          </a>
          <div class="p-5 md:p-6">
            <p class="text-[11px] uppercase tracking-[0.18em] text-gray-500">{currentDevotionalPost.weekLabel}</p>
            <h3 class="font-display text-2xl md:text-3xl text-charcoal mt-2">{currentDevotionalPost.title}</h3>
            <p class="text-gray-600 text-sm mt-3 leading-relaxed">{currentDevotionalPost.excerpt}</p>
            <a href="/devocional" class="mt-5 inline-flex items-center gap-2 text-xs uppercase tracking-[0.18em] text-charcoal hover:text-primary transition-colors">
              Ver video y devocional escrito
              <span class="material-symbols-outlined text-sm">arrow_outward</span>
            </a>
