---
import Layout from "../layouts/Layout.astro";
---
<Layout>
    <div class="h-80 md:height-background bg-[url('/Carousel_3.jpg')]">
        <div class="content-center align-middle p-12">
            <div class="text-center ml-0 md:mt-5 sm:ml-32">
                <h1 class="text-left md:mb-4 text-2xl font-extrabold tracking-tight md:text-5xl lg:text-6xl text-white">
                    Iglesia</h1>
                <h1 class="text-left mb-4 text-2xl font-extrabold tracking-tight text-red-400 md:text-5xl lg:text-6xl">
                    Corazón de Fuego</h1>
                <p class="text-lg font-bold text-white text-left lg:text-xl">Horarios</p>
                <p class="text-left text-lg font-normal text-white lg:text-xl">Miercoles, Viernes y Sabados 20:00hs.</p>
                <p class="text-left text-lg font-normal text-white lg:text-xl">Domingos 9:30 y 11:00 AM</p>
            </div>
        </div>
    </div>
    <div class="justify-center mx-5 md:mx-40 my-5">
        <h1 class="text-justify text-xl md:text-2xl"><span class="font-bold">CORAZÓN DE FUEGO</span> es Lorem ipsum dolor sit amet consectetur, adipisicing elit. Recusandae
            voluptate repellendus magni illo ea animi? Lorem ipsum dolor sit amet consectetur, adipisicing elit. Recusandae
            voluptate repellendus magni illo ea animi? Lorem ipsum dolor sit amet consectetur, adipisicing elit. Recusandae
            voluptate repellendus magni illo ea animi?</h1>
    </div>
    <div class="justify-center">
        <h1 class="text-center mb-4 text-4xl font-extrabold tracking-tight md:text-5xl lg:text-5xl pt-5">SERIES</h1>
    </div>
    <div class="grid grd-cols-1 sm:grid-cols-3 md:grid-cols-3 my-5">
        <div class="hidden md:flex bg-gray-200 rounded-lg mr-10 ml-20 relative group cursor-pointer">
            <a class="group-hover:scale-105" style="transition: 0.3s" href="#">
                <img class="group-hover:blur-sm object-cover w-full shadow-2xl rounded-lg h-full" alt="Serie" src="/Serie_Caminos.jpg">
                <div class="opacity-0 group-hover:opacity-100 flex transition-opacity duration-300 absolute inset-0 items-center justify-center">
                    <div class="p-4 bg-transparent text-gray-800 text-4xl font-bold">
                        ¡Anterior!
                    </div>
                </div>
            </a>
        </div>
        <div class="flex h-96 mx-4 md:mx-10 bg-gray-200 rounded-lg relative group cursor-pointer">
            <a id="delayedRedirectButton" class="group-hover:scale-105" style="transition: 0.3s">
                <img class="group-hover:blur-sm object-cover w-full shadow-2xl rounded-lg h-full" alt="Serie" src="/Serie_Caminos.jpg">
                <div class="opacity-0 group-hover:opacity-100 flex transition-opacity duration-300 absolute inset-0 items-center justify-center">
                    <div class="p-4 bg-transparent text-gray-800 text-4xl font-bold">
                        ¡Ahora!
                    </div>
                </div>
            </a>
        </div>
        <div class="hidden md:flex ml-10 bg-gray-200 rounded-lg mr-20 relative group cursor-pointer">
            <a class="group-hover:scale-105" style="transition: 0.3s">
                <img class="group-hover:blur-sm object-cover w-full shadow-2xl rounded-lg h-full" alt="Serie" src="/Serie_Caminos.jpg">
                <div class="opacity-0 group-hover:opacity-100 flex transition-opacity duration-300 absolute inset-0 items-center justify-center">
                    <div class="p-4 bg-transparent text-gray-800 text-4xl font-bold">
                        ¡Proximamente!
                    </div>
                </div>
            </a>
        </div>
    </div>
    <div class="justify-center">
        <h1 class="text-center mb-4 text-4xl font-extrabold tracking-tight md:text-5xl lg:text-5xl pt-5">CONOCENOS</h1>
    </div>
    <div class="cursor-pointer relative my-5 h-96 overflow-hidden rounded-2xl shadow-lg mx-4 lg:mx-20 group">
        <!-- Contenedor del carousel -->
        <div id="slider" class="flex transition-transform duration-700 ease-out">
            <div class="relative w-full flex-shrink-0">
                <a href="#" class="block w-full h-96">
                    <img src="/Carousel_1.jpg" class="w-full h-96 object-cover group-hover:blur-sm transition duration-300" alt="Slide 1">
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition duration-300">
                        <p class="text-white text-3xl font-bold bg-opacity-50 px-4 py-2 rounded-lg">
                            Texto Slide 1
                        </p>
                    </div>
                </a>
            </div>
            <div class="relative w-full flex-shrink-0">
                <a href="#" class="block w-full h-96">
                    <img src="/Carousel_2.jpg" class="w-full h-96 object-cover group-hover:blur-sm transition duration-300" alt="Slide 2">
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition duration-300">
                        <p class="text-white text-3xl font-bold bg-opacity-50 px-4 py-2 rounded-lg">
                            Texto Slide 2
                        </p>
                    </div>
                </a>
            </div>
            <div class="relative w-full flex-shrink-0">
                <a href="#" class="block w-full h-96">
                    <img src="/Carousel_3.jpg" class="w-full h-96 object-cover group-hover:blur-sm transition duration-300" alt="Slide 3">
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition duration-300">
                        <p class="text-white text-3xl font-bold bg-opacity-50 px-4 py-2 rounded-lg">
                            Texto Slide 3
                        </p>
                    </div>
                </a>
            </div>
        </div>
        <!-- Botones de navegación -->
        <button id="prev" class="mx-5 absolute left-0 top-1/2 transform -translate-y-1/2 px-4 py-2 bg-gray-800 text-white rounded-full focus:outline-none hover:bg-gray-700">
            ❮
        </button>
        <button id="next" class="mx-5 absolute right-0 top-1/2 transform -translate-y-1/2 px-4 py-2 bg-gray-800 text-white rounded-full focus:outline-none hover:bg-gray-700">
            ❯
        </button>

        <!-- Indicadores de posición -->
        <div id="indicators" class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2">
            <span class="indicator w-3 h-3 bg-gray-400 rounded-full"></span>
            <span class="indicator w-3 h-3 bg-gray-400 rounded-full"></span>
            <span class="indicator w-3 h-3 bg-gray-400 rounded-full"></span>
        </div>
    </div>

    <!-- Ventana modal -->
    <div id="modal" class="card-container fixed inset-0 bg-gray-800 bg-opacity-50 flex transition-opacity-300 items-center justify-center hidden">
        <div class="relative flex items-center justify-center bg-gradient-to-r scale-75 lg:scale-100 mt-10  from-orange-400 to-red-500 rounded-xl p-8 shadow-lg max-w-2xl mx-auto">
            <!-- Cuadrado trasero -->
            <div class="hidden md:flex absolute top-24 left-0 w-40 h-40 p-5 bg-yellow-400 rounded-lg shadow-lg -translate-x-6 -translate-y-6">
                <img src="./Arde_PNG.png" class="justify-center mt-2" alt="Arde_PNG"></img>
            </div>
            <!-- Contenido principal -->
            <div class="relative bg-white p-6 md:ml-32 rounded-xl shadow-lg">
                <button id="closeModal" class="top-0 right-0 px-4 py-2 m-3 rounded-xl text-white font-bold bg-orange-500 absolute">X</button>
                <p class="text-sm text-gray-500 mb-2">26 December 2019</p>
                <h2 class="text-2xl font-bold text-gray-800 mb-4">ARDE Adolescentes</h2>
                <p class="text-base font-light text-gray-600 mb-4">
                    Lorem ipsum dolor sit amet consectetur, adipisicing elit. Recusandae
                    voluptate repellendus magni illo ea animi?
                </p>
                <p class="text-base font-light text-gray-600 mb-4">
                    Lorem ipsum dolor sit amet consectetur, adipisicing elit. Recusandae
                    voluptate repellendus magni illo ea animi?
                </p>
                <p class="text-base font-light text-gray-600 mb-4">
                    Lorem ipsum dolor sit amet consectetur, adipisicing elit. Recusandae
                    voluptate repellendus magni illo ea animi?
                </p>
                <button class="bg-gradient-to-r from-orange-500 to-red-500 text-white py-2 px-4 rounded-md shadow-md hover:opacity-90">
                    READ MORE
                </button>
            </div>
        </div>
    </div>
</Layout>
<style is:global>
    html {
        font-family: "Poppins", sans-serif;
        font-weight: 400;
        font-style: normal;
    }

    @tailwind base;
    @tailwind components;
    @tailwind utilities;

    @layer utilities {
        .height-background {
            height: 32rem;
        }
    }

    .height-mobile{
        height: 16rem;
    }

    .py-18 {
        padding-top: 4.5rem /* 64px */;
        padding-bottom: 4.5rem /* 64px */;
    }

    .indicator {
        cursor: pointer;
        transition: background-color 0.3s;
    }
    .indicator:hover {
        background-color: #2d3748; /* Hover fondo más oscuro */
    }

</style>
<script>

    const slider = document.getElementById('slider');
    const prev = document.getElementById('prev');
    const next = document.getElementById('next');
    const indicators = document.querySelectorAll('.indicator');

    let index = 0; // Controla la diapositiva activa

    // Actualizar el slider y el indicador actual
    const updateSlider = () => {
        slider.style.transform = `translateX(-${index * 100}%)`;
        indicators.forEach((dot, i) => {
            dot.classList.toggle('bg-gray-400', i !== index); // Fondo gris cuando inactivo
            dot.classList.toggle('bg-gray-800', i === index); // Fondo oscuro cuando activo
        });
    };

    // Manejadores de eventos de los botones
    next.addEventListener('click', () => {
        index = (index + 1) % slider.children.length;
        updateSlider();
    });

    prev.addEventListener('click', () => {
        index = (index - 1 + slider.children.length) % slider.children.length;
        updateSlider();
    });

    // Inicializar el estado inicial
    updateSlider();

    // Implementación de Swipe para móviles y Drag para mouse
    let startX = 0; // Posición inicial de X al tocar o hacer clic
    let isDragging = false;

    // Manejadores para Touch y Mouse
    const startDrag = (e) => {
        isDragging = true;
        startX = e.type === 'touchstart' ? e.touches[0].clientX : e.clientX;
    };

    const endDrag = (e) => {
        if (!isDragging) return;
        isDragging = false;

        const endX = e.type === 'touchend' ? e.changedTouches[0].clientX : e.clientX;
        const deltaX = endX - startX;

        // Detectar dirección del swipe/drag y navegar
        if (deltaX > 50) {
            // Swipe a la derecha
            index = (index - 1 + slider.children.length) % slider.children.length;
        } else if (deltaX < -50) {
            // Swipe a la izquierda
            index = (index + 1) % slider.children.length;
        }

        updateSlider();
    };

    const dragMove = (e) => {
        if (!isDragging) return;
        // (Opcional) Puedes usar esto para una funcionalidad adicional en scroll en vivo
    };

    // Agregar eventos touch y mouse al contenedor del slider
    slider.addEventListener('touchstart', startDrag);
    slider.addEventListener('touchmove', dragMove);
    slider.addEventListener('touchend', endDrag);
    slider.addEventListener('mousedown', startDrag);
    window.addEventListener('mousemove', dragMove);
    window.addEventListener('mouseup', endDrag);

    // Referencias
    const modal = document.getElementById('modal');
    const openModalButton = document.getElementById('openModal');
    const closeModalButton = document.getElementById('closeModal');

    // Agregar eventos
    openModalButton.addEventListener('click', () => {
        modal.classList.remove('hidden'); // Mostrar el modal
    });

    closeModalButton.addEventListener('click', () => {
        modal.classList.add('hidden'); // Ocultar el modal al presionar la X
    });

    // Cerrar el modal al hacer clic fuera de la ventana modal
    modal.addEventListener('click', (e) => {
        if (e.target === modal) {
            modal.classList.add('hidden');
        }
    });

    button.addEventListener('click', () => {
        // Agrega un delay de 2 segundos (2000 ms) antes de redirigir
        setTimeout(() => {
            window.location.href = '#'; // Cambia por la URL a la que quieres redirigir
        }, 1000); // 2000 ms = 2 segundos
    });
</script>