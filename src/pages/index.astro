---
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Navbar from '../components/Navbar.astro';
import { devotionalPosts } from '../data/devotionals';
import { missions } from '../data/missions';
import { ministries } from '../data/ministries';
import BaseLayout from '../layouts/BaseLayout.astro';

const logoSlugs = new Set(['gold', 'kids', 'arde']);
const currentDevotionalPost = devotionalPosts[0];
const featuredMissions = [...missions]
  .sort((a, b) => new Date(b.startDate).getTime() - new Date(a.startDate).getTime())
  .slice(0, 2);
---

<BaseLayout>
  <Navbar />
  <Hero />

  <section data-animate="reveal" class="py-14 md:py-16 bg-white text-white">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="mb-6 md:mb-8">
        <p class="text-primary text-xs font-bold tracking-[0.22em] uppercase mb-2">Predica destacada</p>
        <h2 data-series-heading class="font-display text-charcoal text-3xl sm:text-4xl font-semibold tracking-tight">Serie actual</h2>
      </div>
      <div class="relative" data-series-carousel>
        <button
          type="button"
          data-series-prev
          aria-label="Serie anterior"
          class="absolute left-2 sm:-left-10 top-1/2 -translate-y-1/2 z-30 text-charcoal/70 text-4xl leading-none hover:text-charcoal transition-colors"
        >
          ‹
        </button>
        <button
          type="button"
          data-series-next
          aria-label="Serie siguiente"
          class="absolute right-2 sm:-right-10 top-1/2 -translate-y-1/2 z-30 text-charcoal/70 text-4xl leading-none hover:text-charcoal transition-colors"
        >
          ›
        </button>

        <div class="relative overflow-hidden rounded-3xl md:rounded-[2rem] h-[520px] sm:h-[560px] md:h-[620px] bg-[#0a0f14]">
          <article data-series-slide class="absolute inset-0 opacity-100 transition-opacity duration-500">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_78%_88%,rgba(255,149,0,0.42),rgba(255,149,0,0.06)_26%,transparent_52%)]"></div>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_95%,rgba(40,177,255,0.45),transparent_28%)]"></div>
            <div class="absolute inset-0 opacity-30 bg-[linear-gradient(180deg,rgba(255,255,255,0.08)_0%,transparent_28%,transparent_72%,rgba(0,0,0,0.28)_100%)]"></div>
            <div class="absolute inset-0 opacity-25 bg-[url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22 viewBox=%220 0 60 60%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%23ffffff%22 fill-opacity=%220.12%22%3E%3Ccircle cx=%223%22 cy=%223%22 r=%221%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>

            <div class="relative z-10 h-full w-full px-6 sm:px-10 lg:px-14 py-10">
              <div class="absolute left-6 top-10 sm:left-10 lg:left-14 max-w-[210px] text-xs sm:text-sm text-white/65 leading-relaxed">
                Mas el herido fue por nuestras rebeliones, molido por nuestros pecados; y por su llaga fuimos nosotros curados.
              </div>
              <div class="hidden sm:block absolute right-6 bottom-5 sm:right-10 sm:bottom-6 lg:right-14 lg:bottom-7 max-w-[220px] text-xs sm:text-sm text-white/60 leading-relaxed text-right">
                Les aseguro que, si tienen confianza y no dudan, del poder de Dios, todo lo que pidan en sus oraciones sucedera.
              </div>

              <div class="absolute inset-x-0 top-6 sm:top-8 md:top-10 text-center flex flex-col items-center">
                <h2 data-animate="card" class="font-display font-semibold text-[#f6f4ee] text-6xl sm:text-7xl lg:text-9xl leading-none tracking-tight lowercase">
                  sanados
                </h2>
                <p data-animate="card" class="mt-4 text-xs sm:text-sm tracking-[0.42em] uppercase text-white/85">
                  serie marzo
                </p>
              </div>

              <div class="absolute inset-0 flex items-center justify-center pt-8 sm:pt-10">
                <a
                  data-animate="card"
                  href="https://www.youtube.com/live/t2G5MA5EWQc?si=4qoAU6x8huFRb5L_"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group relative block h-[130px] sm:h-[168px] w-[285px] sm:w-[380px] overflow-hidden rounded-xl border border-white/20 bg-black/30 backdrop-blur-sm"
                >
                  <img
                    src="https://i.ytimg.com/vi/t2G5MA5EWQc/maxresdefault.jpg"
                    alt="Serie Sanados"
                    class="h-full w-full object-cover object-center opacity-90 transition duration-500 group-hover:scale-105 group-hover:opacity-100"
                  />
                  <span class="absolute inset-0 flex items-center justify-center">
                    <span class="flex h-12 w-12 items-center justify-center rounded-full bg-black/60 text-white text-xl">▶</span>
                  </span>
                </a>
              </div>

              <p data-animate="card" class="absolute left-1/2 -translate-x-1/2 bottom-5 sm:bottom-6 text-xs sm:text-sm tracking-[0.3em] uppercase text-white/80 whitespace-nowrap">
                iglesia corazon de fuego
              </p>

              <span class="absolute left-8 bottom-14 text-white/85 text-5xl font-bold rotate-6">+</span>
              <span class="absolute left-28 top-14 text-white/85 text-5xl font-bold -rotate-12">+</span>
              <span class="hidden sm:block absolute right-10 bottom-36 text-white/80 text-5xl font-bold rotate-[32deg]">-</span>
              <span class="hidden sm:block absolute right-[30%] top-[52%] text-[#ffbe8a] text-7xl font-bold rotate-[22deg]">+</span>
            </div>
          </article>

          <article data-series-slide class="absolute inset-0 opacity-0 pointer-events-none transition-opacity duration-500">
            <div class="absolute inset-0 bg-[#1b120c]"></div>
            <div
              class="absolute inset-0 opacity-85"
              style="background: repeating-linear-gradient(180deg, rgba(255,170,82,0.46) 0px, rgba(255,170,82,0.46) 3px, rgba(46,25,14,0.9) 3px, rgba(46,25,14,0.9) 36px);"
            ></div>
            <div
              class="absolute inset-0"
              style="background: radial-gradient(circle at 62% 48%, rgba(255,167,72,0.36), rgba(255,167,72,0.1) 34%, transparent 60%);"
            ></div>
            <div class="absolute right-0 top-0 h-full w-[22%] bg-gradient-to-l from-black/70 via-black/35 to-transparent"></div>
            <div class="absolute inset-0 opacity-20 bg-[url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2264%22 height=%2264%22 viewBox=%220 0 64 64%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%23ffcf88%22 fill-opacity=%220.2%22%3E%3Ccircle cx=%223%22 cy=%223%22 r=%221%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
            <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.12)_0%,rgba(0,0,0,0.58)_72%,rgba(0,0,0,0.72)_100%)]"></div>

            <div class="relative z-10 h-full w-full px-6 sm:px-10 lg:px-14 py-10">
              <div class="absolute inset-x-0 top-6 sm:top-8 md:top-10 text-center flex flex-col items-center">
                <h2 data-animate="card" class="font-display font-semibold text-[#ffd074] text-5xl sm:text-7xl lg:text-8xl leading-none tracking-tight uppercase">
                  descanso
                </h2>
                <p data-animate="card" class="mt-4 text-xs sm:text-sm tracking-[0.42em] uppercase text-[#ffd074]/90">
                  serie febrero 2026
                </p>
              </div>

              <div class="absolute inset-0 flex items-center justify-center pt-8 sm:pt-10">
                <a
                  data-animate="card"
                  href="https://www.youtube.com/live/4Vc9WsM4SlY?si=T83Ax_e5yMpvljs-"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group relative block h-[130px] sm:h-[168px] w-[285px] sm:w-[380px] overflow-hidden rounded-xl border border-white/20 bg-black/40 backdrop-blur-sm"
                >
                  <img
                    src="https://i.ytimg.com/vi/4Vc9WsM4SlY/maxresdefault.jpg"
                    alt="Serie Descanso"
                    class="h-full w-full object-cover object-center opacity-90 transition duration-500 group-hover:scale-105 group-hover:opacity-100"
                  />
                  <span class="absolute inset-0 flex items-center justify-center">
                    <span class="flex h-12 w-12 items-center justify-center rounded-full bg-black/60 text-white text-xl">▶</span>
                  </span>
                </a>
              </div>

              <p data-animate="card" class="absolute left-1/2 -translate-x-1/2 bottom-5 sm:bottom-6 text-xs sm:text-sm tracking-[0.3em] uppercase text-white/80 whitespace-nowrap">
                iglesia corazon de fuego
              </p>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const carousel = document.querySelector('[data-series-carousel]');
      if (!carousel) return;

      const slides = [...carousel.querySelectorAll('[data-series-slide]')];
      const prev = carousel.querySelector('[data-series-prev]');
      const next = carousel.querySelector('[data-series-next]');
      const heading = document.querySelector('[data-series-heading]');
      let index = 0;

      const render = () => {
        slides.forEach((slide, i) => {
          const active = i === index;
          slide.classList.toggle('opacity-100', active);
          slide.classList.toggle('opacity-0', !active);
          slide.classList.toggle('pointer-events-none', !active);
          slide.setAttribute('aria-hidden', String(!active));
        });

        if (heading) {
          heading.textContent = index === 0 ? 'Serie actual' : 'Series anteriores';
        }
      };

      prev?.addEventListener('click', () => {
        index = (index - 1 + slides.length) % slides.length;
        render();
      });

      next?.addEventListener('click', () => {
        index = (index + 1) % slides.length;
        render();
      });

      render();
    })();
  </script>

  <section data-animate="reveal" class="py-14 md:py-12 bg-white" id="novedades">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-8 md:mb-10">
        <div>
          <h2 class="font-display text-3xl sm:text-4xl text-charcoal mb-2">Comunidad / Novedades</h2>
          <p class="text-gray-500 max-w-md">Entérate de lo que está sucediendo en nuestra casa.</p>
        </div>
        <div class="hidden md:flex gap-2">
          <a class="text-xs font-bold uppercase tracking-widest text-charcoal border-b border-charcoal pb-1 hover:text-primary hover:border-primary transition-colors" href="/calendario">Ver todo el calendario</a>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-8">
        <div data-animate="card" class="md:col-span-2 relative w-full h-[360px] sm:h-[420px] md:h-[450px] rounded-2xl md:rounded-3xl overflow-hidden shadow-lg group">
          <img alt="Special Event" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCqt-aObF-AnhXTv7XjqD6KvggMW2EEui1Ik8I-i2GiKoQ2CNr7_P24W4Fe3akxTSVQGxzef6d3GPCRk5oMeZuCmQDrlNPANGJ7kadC3yLNUl4aMZtQPG-YF1Eb0iKlypaG1eyUxsF_D8mWS6b2rU6t_aRBrCjI2qD39sRnNVIMkvNa8CbhLbIR4fssR_0uUHKuXkWfx2ykECnf_eoBeOdTr5OaP1rh-8itwkKCLbr5igTePke3IGdMKa-GghaL74dBJInwc_jW1OU" />
          <div class="absolute inset-0 bg-gradient-to-t from-charcoal/90 via-charcoal/20 to-transparent flex flex-col justify-end p-6 sm:p-8 md:p-10">
            <span class="bg-primary text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider w-fit mb-3">Destacado</span>
            <h3 class="font-display text-2xl sm:text-3xl md:text-4xl text-white leading-tight mb-2">
              Congreso "Renovando el Entendimiento"
            </h3>
            <p class="text-gray-200 text-sm md:text-base max-w-lg mb-4 md:mb-6 font-light">
              Tres días de conferencias, adoración y transformación con invitados especiales.
            </p>
            <div>
              <a class="inline-flex items-center gap-2 text-white border-b border-white/50 pb-1 text-sm font-bold tracking-wider hover:border-primary hover:text-primary transition-colors" href="#">
                INSCRÍBETE AHORA
              </a>
            </div>
          </div>
        </div>
        <div class="flex flex-col gap-5 md:gap-8 h-auto md:h-[450px]">
          <div data-animate="card" class="relative min-h-[205px] md:min-h-0 flex-1 rounded-2xl md:rounded-3xl overflow-hidden shadow-md group bg-light-gray">
            <div class="absolute inset-0 p-6 flex flex-col justify-center items-start z-10">
              <span class="text-xs font-bold text-primary uppercase tracking-widest mb-2">Miércoles</span>
              <h3 class="font-display text-2xl text-charcoal mb-2">Estudio Bíblico</h3>
              <p class="text-gray-600 text-sm mb-4">Profundizando en las escrituras cada semana.</p>
              <a class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-charcoal hover:bg-charcoal hover:text-white transition-colors shadow-sm" href="#">
                <span class="material-symbols-outlined text-sm">arrow_outward</span>
              </a>
            </div>
            <img alt="Bible Study" class="absolute right-0 bottom-0 w-2/3 h-2/3 object-cover opacity-20 group-hover:opacity-30 transition-opacity" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCt1G7t_8Q4dc8IolCJZLjvo0te82Mu7rReT0tKYkBzYGZqtFaWcZuAR3l9SGZ4EM_w6bT5QHkDDdqgBHPszl0rNahTy4tGrMKt4NJsqCdWBH7eIl7IZ9M-qfNGuYA7kZdrFcD5Tfv1NOf7rZI8Uj_wVCtUY8tzIGArMZi5zALlFBK3le6XB0kaQ00Ujq40ujoeS1S9J_mCjv2IumvVXSv4avRPdoj2B6MXNKkTWa4eXjFoEu-5tDZEOu06C2DWSMucH6XnAKSXxRc" />
          </div>
          <div data-animate="card" class="relative min-h-[205px] md:min-h-0 flex-1 rounded-2xl md:rounded-3xl overflow-hidden shadow-md group bg-charcoal text-white">
