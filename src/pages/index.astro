        </div>
        <div class="mt-6 md:mt-0 relative z-10 flex flex-col md:flex-row items-center gap-4 md:gap-6">
          <span class="px-4 py-1.5 bg-primary text-charcoal text-xs font-bold uppercase tracking-wider rounded-full">Próximamente</span>
