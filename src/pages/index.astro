  <section data-animate="reveal" class="py-14 md:py-16 bg-white" id="institucional">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-8 md:mb-10">
        <div>
          <h2 class="font-display text-3xl sm:text-4xl text-charcoal mb-2">Institucional</h2>
          <p class="text-gray-500 max-w-2xl">Espacio para presentar la formacion, vision y procesos de crecimiento de la casa.</p>
