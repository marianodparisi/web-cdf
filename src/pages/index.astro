---
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Navbar from '../components/Navbar.astro';
import { devotionalPosts } from '../data/devotionals';
import { ministries } from '../data/ministries';
import BaseLayout from '../layouts/BaseLayout.astro';

const logoSlugs = new Set(['gold', 'kids', 'arde']);
const currentDevotionalPost = devotionalPosts[0];
const exodoYoutubeUrl = 'https://www.youtube.com/playlist?list=PLbq3XgHcmjEtwhYdGCqO8PqbFY7EMFI5p';
const getYouTubeEmbedUrl = (videoUrl?: string) => {
  if (!videoUrl) return null;
  try {
    const url = new URL(videoUrl);
    const idFromPath = url.pathname.startsWith('/live/') ? url.pathname.split('/live/')[1] : null;
    const idFromQuery = url.searchParams.get('v');
    const videoId = idFromQuery || idFromPath;
    return videoId ? `https://www.youtube.com/embed/${videoId}` : videoUrl;
  } catch {
    return videoUrl;
  }
};
const currentDevotionalEmbedUrl = getYouTubeEmbedUrl(currentDevotionalPost?.videoUrl);
---

<BaseLayout>
  <Navbar />
  <Hero />

  <section data-animate="reveal" class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-[1.05fr_0.95fr] md:items-center md:gap-14">
        <div>
          <p class="mb-3 text-xs font-bold uppercase tracking-[0.22em] text-primary">Quiénes somos</p>
          <h2 class="font-display text-4xl font-semibold leading-[1.05] tracking-tight text-charcoal sm:text-5xl lg:text-6xl">
            Existimos para ministrar al Señor y encender una generación.
          </h2>
        </div>
        <div>
          <p class="max-w-2xl text-base leading-relaxed text-gray-600 sm:text-lg">
            Iglesia Corazón de Fuego es una casa de adoración, oración y formación. Nos reunimos para darle a Dios gratitud y alabanza, afirmar quién es Él, interceder por lo que desea hacer y caminar como familia en el propósito que nos confió.
          </p>
          <a class="mt-8 inline-flex items-center gap-2 border-b border-charcoal pb-1 text-xs font-bold uppercase tracking-widest text-charcoal transition-colors hover:border-primary hover:text-primary" href="/nosotros">
            Conocé más de nosotros
            <span class="material-symbols-outlined text-sm">arrow_outward</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="py-14 md:py-16 bg-white text-white">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="mb-6 md:mb-8">
        <h2 data-series-heading class="font-display text-charcoal text-3xl sm:text-4xl font-semibold tracking-tight">Serie actual</h2>
      </div>
      <div class="relative" data-series-carousel>
        <button
          type="button"
          data-series-prev
          aria-label="Serie anterior"
          class="absolute left-2 sm:-left-10 top-1/2 -translate-y-1/2 z-30 text-charcoal/70 text-4xl leading-none hover:text-charcoal transition-colors"
        >
          ‹
        </button>
        <button
          type="button"
          data-series-next
          aria-label="Serie siguiente"
          class="absolute right-2 sm:-right-10 top-1/2 -translate-y-1/2 z-30 text-charcoal/70 text-4xl leading-none hover:text-charcoal transition-colors"
        >
          ›
        </button>

        <div class="relative overflow-hidden rounded-3xl md:rounded-[2rem] h-[520px] sm:h-[560px] md:h-[620px] bg-[#0a0f14]">
          <article data-series-slide class="absolute inset-0 opacity-100 transition-opacity duration-500">
            <picture class="absolute inset-0 block h-full w-full">
              <source media="(min-width: 768px)" srcset="/exododesktop.jpg" />
              <img
                src="/exodomobile.jpg"
                alt="Nueva serie Exodo"
                class="h-full w-full object-cover object-center"
              />
            </picture>
            <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-black/10 to-black/20"></div>
            <a
              href={exodoYoutubeUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Abrir playlist de Exodo en YouTube"
              class="absolute inset-0 z-10 block lg:hidden"
            ></a>

            <div class="relative z-10 flex h-full w-full items-start justify-end px-6 py-6 sm:px-10 sm:py-8 lg:px-14 lg:py-10">
              <span
                data-animate="card"
                class="inline-flex rounded-full border border-white/25 bg-black/20 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.28em] text-white/90 backdrop-blur-sm sm:text-xs"
              >
                Nueva serie
              </span>
            </div>

            <div class="absolute inset-x-0 bottom-0 z-10 hidden px-10 pb-10 lg:flex">
              <a
                href={exodoYoutubeUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 rounded-full border border-white/20 bg-black/35 px-5 py-3 text-sm font-semibold uppercase tracking-[0.22em] text-white backdrop-blur-sm transition hover:border-white/40 hover:bg-black/50"
              >
                <span class="flex h-9 w-9 items-center justify-center rounded-full bg-[#ff0000] text-white">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      fill="currentColor"
                      d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31.4 31.4 0 0 0 0 12a31.4 31.4 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31.4 31.4 0 0 0 24 12a31.4 31.4 0 0 0-.5-5.8ZM9.6 15.6V8.4L15.8 12l-6.2 3.6Z"
                    />
                  </svg>
                </span>
                Ver en YouTube
              </a>
            </div>
          </article>

          <article data-series-slide class="absolute inset-0 opacity-0 pointer-events-none transition-opacity duration-500">
            <div class="absolute inset-0 bg-[#1b120c]"></div>
            <div
              class="absolute inset-0 opacity-85"
              style="background: repeating-linear-gradient(180deg, rgba(255,170,82,0.46) 0px, rgba(255,170,82,0.46) 3px, rgba(46,25,14,0.9) 3px, rgba(46,25,14,0.9) 36px);"
            ></div>
            <div
              class="absolute inset-0"
              style="background: radial-gradient(circle at 62% 48%, rgba(255,167,72,0.36), rgba(255,167,72,0.1) 34%, transparent 60%);"
            ></div>
            <div class="absolute right-0 top-0 h-full w-[22%] bg-gradient-to-l from-black/70 via-black/35 to-transparent"></div>
            <div class="absolute inset-0 opacity-20 bg-[url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2264%22 height=%2264%22 viewBox=%220 0 64 64%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%23ffcf88%22 fill-opacity=%220.2%22%3E%3Ccircle cx=%223%22 cy=%223%22 r=%221%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')]"></div>
            <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0.12)_0%,rgba(0,0,0,0.58)_72%,rgba(0,0,0,0.72)_100%)]"></div>

            <div class="relative z-10 h-full w-full px-6 sm:px-10 lg:px-14 py-10">
              <div class="absolute inset-x-0 top-6 sm:top-8 md:top-10 text-center flex flex-col items-center">
                <h2 data-animate="card" class="font-display font-semibold text-[#ffd074] text-5xl sm:text-7xl lg:text-8xl leading-none tracking-tight uppercase">
                  descanso
                </h2>
                <p data-animate="card" class="mt-4 text-xs sm:text-sm tracking-[0.42em] uppercase text-[#ffd074]/90">
                  serie febrero 2026
                </p>
              </div>

              <div class="absolute inset-0 flex items-center justify-center pt-8 sm:pt-10">
                <a
                  data-animate="card"
                  href="https://www.youtube.com/live/4Vc9WsM4SlY?si=T83Ax_e5yMpvljs-"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group relative block h-[130px] sm:h-[168px] w-[285px] sm:w-[380px] overflow-hidden rounded-xl border border-white/20 bg-black/40 backdrop-blur-sm"
                >
                  <img
                    src="https://i.ytimg.com/vi/4Vc9WsM4SlY/maxresdefault.jpg"
                    alt="Serie Descanso"
                    class="h-full w-full object-cover object-center opacity-90 transition duration-500 group-hover:scale-105 group-hover:opacity-100"
                  />
                  <span class="absolute inset-0 flex items-center justify-center">
                    <span class="flex h-12 w-12 items-center justify-center rounded-full bg-[#ff0000] text-white">
                      <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
                        <path
                          fill="currentColor"
                          d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31.4 31.4 0 0 0 0 12a31.4 31.4 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31.4 31.4 0 0 0 24 12a31.4 31.4 0 0 0-.5-5.8ZM9.6 15.6V8.4L15.8 12l-6.2 3.6Z"
                        />
                      </svg>
                    </span>
                  </span>
                </a>
              </div>

              <p data-animate="card" class="absolute left-1/2 -translate-x-1/2 bottom-5 sm:bottom-6 text-xs sm:text-sm tracking-[0.3em] uppercase text-white/80 whitespace-nowrap">
                iglesia corazon de fuego
              </p>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const carousel = document.querySelector('[data-series-carousel]');
      if (!carousel) return;

      const slides = [...carousel.querySelectorAll('[data-series-slide]')];
      const prev = carousel.querySelector('[data-series-prev]');
      const next = carousel.querySelector('[data-series-next]');
      const heading = document.querySelector('[data-series-heading]');
      let index = 0;

      const render = () => {
        slides.forEach((slide, i) => {
          const active = i === index;
          slide.classList.toggle('opacity-100', active);
          slide.classList.toggle('opacity-0', !active);
          slide.classList.toggle('pointer-events-none', !active);
          slide.setAttribute('aria-hidden', String(!active));
        });

        if (heading) {
          heading.textContent = index === 0 ? 'Serie actual' : 'Series anteriores';
        }
      };

      prev?.addEventListener('click', () => {
        index = (index - 1 + slides.length) % slides.length;
        render();
      });

      next?.addEventListener('click', () => {
        index = (index + 1) % slides.length;
        render();
      });

      render();
    })();
  </script>

  <section data-animate="reveal" class="py-14 md:py-12 bg-white" id="novedades">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-8 md:mb-10">
        <div>
          <h2 class="font-display text-3xl sm:text-4xl text-charcoal mb-2">Anuncio / Novedades</h2>
          <p class="text-gray-500 max-w-md">Entérate de lo que está sucediendo en nuestra casa.</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-8">
        <div data-animate="card" class="md:col-span-2 relative w-full h-[360px] sm:h-[420px] md:h-[450px] rounded-2xl md:rounded-3xl overflow-hidden shadow-lg group">
          <img alt="Anuncio GOLD" class="absolute left-0 top-[-0.5rem] w-full h-auto max-w-none transition-transform duration-700 group-hover:scale-[1.02]" src="/goldanuncio.jpg" />
          <div class="absolute inset-0 bg-gradient-to-t from-charcoal/90 via-charcoal/20 to-transparent flex flex-col justify-end p-6 sm:p-8 md:p-10">
            <span class="bg-primary text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider w-fit mb-3">Destacado</span>
            <h3 class="font-display text-2xl sm:text-3xl md:text-4xl text-white leading-tight mb-2">
              Encuentro GOLD
            </h3>
            <p class="text-gray-200 text-sm md:text-base max-w-lg mb-4 md:mb-6 font-light">
              Un tiempo especial para compartir palabra, compañerismo y crecimiento.
            </p>
            <div>
              <a class="inline-flex items-center gap-2 text-white border-b border-white/50 pb-1 text-sm font-bold tracking-wider hover:border-primary hover:text-primary transition-colors" href="/ministerios/gold">
                Ver más
              </a>
            </div>
          </div>
        </div>
        <div class="flex flex-col gap-5 md:gap-8 h-auto md:h-[450px]">
          <a data-animate="card" href="/ministerios/arde" class="relative min-h-[205px] md:min-h-0 flex-1 rounded-2xl md:rounded-3xl overflow-hidden shadow-md group bg-charcoal">
            <img alt="Campamento ARDE" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" src="/campaarde.jpg" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-5 sm:p-6 z-10">
              <span class="inline-flex rounded-full bg-primary px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold mb-3">Campa ARDE</span>
              <h3 class="font-display text-2xl text-white mb-2">Campamento ARDE</h3>
              <p class="text-white/80 text-sm">Una experiencia para adolescentes con amigos, palabra y dias que no se olvidan facil.</p>
            </div>
          </a>
          <a data-animate="card" href="/ministerios/kids" class="relative min-h-[205px] md:min-h-0 flex-1 rounded-2xl md:rounded-3xl overflow-hidden shadow-md group bg-charcoal text-white">
            <img alt="Campa Kids" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" src="/campakids.jpg" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/15 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-5 sm:p-6 z-10">
              <span class="inline-flex rounded-full bg-primary px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold mb-3">Campa Kids</span>
              <h3 class="font-display text-2xl text-white mb-2">Campamento Kids</h3>
              <p class="text-white/80 text-sm">Una aventura para que los chicos aprendan, jueguen y vivan la fe con alegria.</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="py-14 md:py-16 bg-white" id="devocional">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-8 md:mb-10">
        <div>
          <h2 class="font-display text-3xl sm:text-4xl text-charcoal mb-2">Devocional Actual</h2>
          <p class="text-gray-500 max-w-2xl">Palabra y video de la semana para caminar el devocional diario.</p>
        </div>
        <a class="hidden md:inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-charcoal border-b border-charcoal pb-1 hover:text-primary hover:border-primary transition-colors" href="/devocional">
          Ver devocional
          <span class="material-symbols-outlined text-sm">arrow_outward</span>
        </a>
      </div>
      {currentDevotionalPost && (
        <article data-animate="card" class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-6 md:gap-8 items-stretch rounded-3xl border border-gray-200 bg-gray-50 p-5 sm:p-6 md:p-8">
          <div class="flex flex-col justify-center">
            <div class="flex flex-wrap items-center gap-2">
              <span class="inline-flex rounded-full bg-gray-100 px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold">{currentDevotionalPost.weekLabel}</span>
              <span class="inline-flex rounded-full bg-primary px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold">Actual</span>
            </div>
            <h3 class="font-display text-3xl md:text-4xl text-charcoal mt-4">{currentDevotionalPost.title}</h3>
            <p class="text-gray-600 text-sm sm:text-base mt-4 leading-relaxed">{currentDevotionalPost.excerpt}</p>
            <a href="/devocional" class="mt-6 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-charcoal hover:text-primary transition-colors">
              Ir al devocional
              <span class="material-symbols-outlined text-sm">arrow_outward</span>
            </a>
          </div>

          <div class="relative overflow-hidden rounded-2xl bg-charcoal shadow-sm lg:max-h-[320px]">
            {currentDevotionalEmbedUrl ? (
              <iframe
                class="min-h-[230px] w-full aspect-video lg:h-full lg:aspect-auto"
                src={currentDevotionalEmbedUrl}
                title={currentDevotionalPost.title}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            ) : (
              <a href="/devocional" class="group block h-full min-h-[210px]">
                <img
                  src={currentDevotionalPost.image}
                  alt={currentDevotionalPost.title}
                  class="h-full w-full object-cover translate-y-2 scale-105 transition-transform duration-500 group-hover:translate-y-2 group-hover:scale-110"
                />
              </a>
            )}
          </div>
        </article>
      )}
      <div class="md:hidden mt-6">
        <a class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-charcoal border-b border-charcoal pb-1 hover:text-primary hover:border-primary transition-colors" href="/devocional">
          Ver devocional
          <span class="material-symbols-outlined text-sm">arrow_outward</span>
        </a>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="py-16 md:py-24 bg-gray-50" id="ministerios">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-10 md:mb-16">
        <div>
          <h2 class="font-display text-3xl sm:text-4xl text-charcoal mb-4">Nuestro Liderazgo / Ministerios</h2>
          <p class="text-gray-500 max-w-md">Áreas donde servimos y crecemos juntos como familia.</p>
        </div>
        <a class="hidden md:inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-charcoal border-b border-charcoal pb-1 hover:text-primary hover:border-primary transition-colors" href="/ministerios">
          Ver seccion
          <span class="material-symbols-outlined text-sm">arrow_outward</span>
        </a>
      </div>
      <div class="flex flex-wrap justify-center gap-4 sm:gap-5 lg:gap-6">
        {
          ministries.map((ministry) => (
            <a data-animate="card" class="group flex w-[calc(50%-0.5rem)] min-w-0 max-w-[220px] flex-col items-center text-center md:w-[calc(33.333%-0.85rem)] lg:w-[calc(25%-1rem)] xl:w-[calc(16.666%-1rem)]" href={`/ministerios/${ministry.slug}`}>
              <div class={`relative overflow-hidden rounded-2xl md:rounded-[1.5rem] mb-3 md:mb-4 aspect-[4/5] sm:aspect-[3/4] w-full ${logoSlugs.has(ministry.slug) ? 'bg-white border border-gray-300 p-3' : ''}`}>
                <img
                  alt={`Ministerio ${ministry.name}`}
                  class={`w-full h-full transition duration-500 ${logoSlugs.has(ministry.slug) ? 'object-contain' : 'object-cover group-hover:scale-105'}`}
                  src={ministry.image}
                />
                <div class={`absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4 ${logoSlugs.has(ministry.slug) ? 'bg-gradient-to-t from-charcoal/45 to-transparent' : 'bg-gradient-to-t from-charcoal/80 to-transparent'}`}>
                  <span class="text-white text-xs font-bold uppercase tracking-wider">Ver ministerio</span>
                </div>
              </div>
              <h3 class="font-display text-base sm:text-lg text-charcoal group-hover:text-primary transition-colors">{ministry.name}</h3>
              <p class="text-xs text-gray-500 font-bold uppercase tracking-widest mt-1">{ministry.area}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="py-14 md:py-12 bg-white" id="radio">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="bg-charcoal rounded-2xl md:rounded-3xl p-6 sm:p-8 md:p-16 flex flex-col md:flex-row items-center justify-between relative overflow-hidden">
        <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
        <div class="flex items-center gap-4 sm:gap-6 relative z-10">
          <div class="h-20 w-20 rounded-full bg-white/10 flex items-center justify-center backdrop-blur-md">
            <span class="material-symbols-outlined text-white text-4xl">mic</span>
          </div>
          <div>
            <h2 class="font-display text-2xl sm:text-3xl md:text-4xl text-white mb-2">Radio Corazón</h2>
            <div class="flex items-center gap-3">
              <span class="text-gray-400 text-xs tracking-widest uppercase">La frecuencia del cielo</span>
              <div class="flex items-end gap-[3px] h-3 audio-wave">
                <span></span><span></span><span></span><span></span><span></span>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-6 md:mt-0 relative z-10 flex flex-col md:flex-row items-center gap-4 md:gap-6">
          <span class="px-4 py-1.5 bg-primary text-charcoal text-xs font-bold uppercase tracking-wider rounded-full">Próximamente</span>
          <p class="text-white/60 text-sm font-light italic text-center md:text-right">"24/7 conectados contigo."</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
