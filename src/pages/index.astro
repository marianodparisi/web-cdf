          featuredMissions.map((mission) => (
            <article data-animate="card" class="rounded-3xl overflow-hidden border border-gray-200 bg-white">
              <div class="relative h-52 sm:h-56">
                <img src={mission.image} alt={`Mision ${mission.place}`} class="h-full w-full object-cover" />
