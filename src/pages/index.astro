---
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Navbar from '../components/Navbar.astro';
import { devotionalPosts } from '../data/devotionals';
import { ministries } from '../data/ministries';
import BaseLayout from '../layouts/BaseLayout.astro';

const logoSlugs = new Set(['gold', 'kids', 'arde']);
const currentDevotionalPost = devotionalPosts[0];
const seriesPlaylistUrl = 'https://www.youtube.com/@Coraz%C3%B3ndeFuego/playlists';
const sermonSeries = [
  {
    title: 'Éxodo',
    subtitle: 'El camino hacia la libertad',
    label: 'Serie actual',
    image: '/series/exododesktop.jpg',
    mobileImage: '/series/exodomobile.jpg',
    href: 'https://www.youtube.com/playlist?list=PLbq3XgHcmjEtwhYdGCqO8PqbFY7EMFI5p',
    description:
      'Un recorrido por el libro de Éxodo para ver la fidelidad de Dios, la libertad y el camino hacia su propósito.',
  },
  {
    title: 'Sanados',
    subtitle: 'Restauración para el corazón',
    label: 'Serie anterior',
    image: '/sanadosvertical.jpg',
    href: 'https://www.youtube.com/playlist?list=PLbq3XgHcmjEv4unRsnKoJVVnt9yLDdv4T',
    description: 'Una serie para recibir sanidad, libertad y restauración en Jesús.',
  },
  {
    title: 'Descanso',
    subtitle: 'Serie febrero 2026',
    label: 'Serie anterior',
    image: '/descansovertical.jpg',
    href: 'https://www.youtube.com/playlist?list=PLbq3XgHcmjEuy20aDEPjbTu6MUZhOCUqG',
    description: 'Una serie para volver al ritmo de Dios y aprender a descansar en su presencia.',
  },
  {
    title: 'Pertenecer',
    subtitle: 'Una casa, una familia, un propósito',
    label: 'Serie anterior',
    image: '/pertenecervertical.jpg',
    href: 'https://www.youtube.com/playlist?list=PLbq3XgHcmjEt1a2mr2d-g7-z6tzo7C-HP',
    description: 'Una serie sobre identidad, familia espiritual y el llamado a caminar juntos.',
  },
  {
    title: 'Enviame',
    subtitle: 'Disponibles para responder al llamado',
    label: 'Serie anterior',
    image: '/enviamevertical.jpg',
    href: seriesPlaylistUrl,
    description: 'Una serie sobre disponibilidad, obediencia y misión.',
  },
  {
    title: 'Gozo',
    subtitle: 'La alegría que nace en Dios',
    label: 'Serie anterior',
    image: '/gozovertical.jpg',
    href: seriesPlaylistUrl,
    description: 'Una serie para redescubrir el gozo verdadero en Cristo.',
  },
];
const [currentSeries, ...recentSeries] = sermonSeries;
const getYouTubeEmbedUrl = (videoUrl?: string) => {
  if (!videoUrl) return null;
  try {
    const url = new URL(videoUrl);
    const idFromPath = url.pathname.startsWith('/live/') ? url.pathname.split('/live/')[1] : null;
    const idFromQuery = url.searchParams.get('v');
    const videoId = idFromQuery || idFromPath;
    return videoId ? `https://www.youtube.com/embed/${videoId}` : videoUrl;
  } catch {
    return videoUrl;
  }
};
const currentDevotionalEmbedUrl = getYouTubeEmbedUrl(currentDevotionalPost?.videoUrl);
---

<BaseLayout>
  <Navbar />
  <Hero />

  <section data-animate="reveal" class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-[1.05fr_0.95fr] md:items-center md:gap-14">
        <div>
          <p class="mb-3 text-xs font-bold uppercase tracking-[0.22em] text-primary">Quiénes somos</p>
          <h2 class="font-display text-4xl font-semibold leading-[1.05] tracking-tight text-charcoal sm:text-5xl lg:text-6xl">
            Existimos para ministrar al Señor y encender una generación.
          </h2>
        </div>
        <div>
          <p class="max-w-2xl text-base leading-relaxed text-gray-600 sm:text-lg">
            Iglesia Corazón de Fuego es una casa de adoración, oración y formación. Nos reunimos para darle a Dios gratitud y alabanza, afirmar quién es Él, interceder por lo que desea hacer y caminar como familia en el propósito que nos confió.
          </p>
          <a class="mt-8 inline-flex items-center gap-2 border-b border-charcoal pb-1 text-xs font-bold uppercase tracking-widest text-charcoal transition-colors hover:border-primary hover:text-primary" href="/nosotros">
            Conocé más de nosotros
            <span class="material-symbols-outlined text-sm">arrow_outward</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="min-h-screen bg-[#f3f3f3] py-14 shadow-[inset_0_6px_32px_rgba(0,0,0,0.07),inset_0_-6px_32px_rgba(0,0,0,0.04)] md:py-16">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="mb-12 grid grid-cols-1 gap-6 md:mb-14 lg:grid-cols-3 lg:items-end">
        <div class="lg:col-span-2">
          <p class="mb-3 text-xs font-bold uppercase tracking-[0.24em] text-primary">Series</p>
          <h2 class="font-display text-3xl font-medium tracking-tight text-[#6b7280] sm:text-4xl">Serie actual</h2>
        </div>
        <div>
          <h3 class="font-display text-3xl font-medium tracking-tight text-[#6b7280] sm:text-4xl">Series anteriores</h3>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3 lg:gap-8">
        <a
          data-animate="card"
          href={currentSeries.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Ver serie ${currentSeries.title}`}
          class="group relative block h-[460px] overflow-hidden rounded-[2.5rem] bg-[#f7f7f7] shadow-[0_42px_90px_rgba(0,0,0,0.22),0_16px_38px_rgba(0,0,0,0.16),0_3px_10px_rgba(0,0,0,0.10)] transition-all duration-200 hover:-translate-y-[3px] md:h-[540px] lg:col-span-2"
        >
          <picture class="absolute inset-0 flex h-full w-full items-center justify-center overflow-hidden">
            {currentSeries.mobileImage && <source media="(max-width: 767px)" srcset={currentSeries.mobileImage} />}
            <img
              src={currentSeries.image}
              alt={`Serie ${currentSeries.title}`}
              class="h-full w-full object-cover object-center transition-[filter,transform] duration-700 ease-out [filter:sepia(0.22)_saturate(0.78)_contrast(1.08)_brightness(0.93)] group-hover:scale-105"
            />
          </picture>
          <div class="absolute inset-x-0 top-0 z-10 flex items-start justify-between p-6 sm:p-8">
            <span class="inline-flex w-fit text-sm font-extrabold uppercase tracking-[0.16em] text-white drop-shadow-[0_2px_14px_rgba(0,0,0,0.45)] sm:text-base">
              {currentSeries.label}
            </span>
            <span class="inline-flex w-fit text-sm font-extrabold uppercase tracking-[0.16em] text-white drop-shadow-[0_2px_14px_rgba(0,0,0,0.45)] sm:text-base">
              Abril
            </span>
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-black/10 to-white/10"></div>
          <div class="absolute inset-x-0 bottom-0 h-[48%] bg-gradient-to-t from-white/45 via-white/24 to-transparent backdrop-blur-[2px] [mask-image:linear-gradient(to_top,black_0%,black_62%,transparent_100%)]"></div>
          <div class="absolute inset-x-0 bottom-0 z-10 p-6 sm:p-8 md:p-10">
            <div class="flex max-w-full flex-col gap-4 text-white drop-shadow-[0_2px_18px_rgba(0,0,0,0.35)] md:max-w-[50%]">
              <h3 class="font-display text-3xl font-bold text-white drop-shadow-sm sm:text-4xl md:text-5xl">{currentSeries.title}</h3>
              <p class="line-clamp-2 max-w-xl text-sm leading-relaxed text-white/85">{currentSeries.description}</p>
            </div>
          </div>
          <div class="absolute bottom-6 right-6 z-20 sm:bottom-8 sm:right-8 md:bottom-10 md:right-10">
            <span class="inline-flex items-center gap-2 rounded-full bg-white/20 px-4 py-2 text-xs font-bold uppercase tracking-[0.12em] text-white shadow-[0_12px_35px_rgba(0,0,0,0.18)] backdrop-blur-2xl">
              <span class="material-symbols-outlined text-base">play_circle</span>
              YouTube
            </span>
          </div>
        </a>

        <aside data-animate="card" class="flex h-[460px] flex-col md:h-[540px]">
          <div class="relative min-h-0 flex-1">
            {
              recentSeries.map((series, index) => {
                const imagePosition =
                  series.title === 'Gozo'
                    ? 'object-[center_0%]'
                    : series.title === 'Enviame'
                      ? 'object-[center_34%]'
                      : 'object-center';
                const imageScale =
                  series.title === 'Gozo'
                    ? '-translate-y-2 scale-[1.16] group-hover:-translate-y-3 group-hover:scale-[1.2]'
                    : 'group-hover:scale-105';
                const stackPosition = [
                  'top-[8%] left-[48%] -translate-x-1/2 z-[5]',
                  'top-[22%] left-[30%] -translate-x-1/2 z-[4]',
                  'top-[34%] left-[62%] -translate-x-1/2 z-[3]',
                  'top-[46%] left-[36%] -translate-x-1/2 z-[2]',
                  'top-[58%] left-[68%] -translate-x-1/2 z-[1]',
                ][index] ?? 'top-0 left-1/2 -translate-x-1/2';
                return (
                  <a
                    href={series.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Ver serie ${series.title}`}
                    class={`group absolute block aspect-square w-[9.25rem] overflow-hidden rounded-[28px] bg-[#f7f7f7] shadow-[0_42px_90px_rgba(0,0,0,0.22),0_16px_38px_rgba(0,0,0,0.16),0_3px_10px_rgba(0,0,0,0.10)] transition-all duration-300 hover:z-20 hover:-translate-y-2 sm:w-[10rem] md:w-[10.75rem] lg:w-[8.8rem] xl:w-[9.6rem] ${stackPosition}`}
                  >
                    <img
                      src={series.image}
                      alt={`Serie ${series.title}`}
                      class={`h-full w-full object-cover transition-[filter,transform] duration-700 ease-out [filter:grayscale(1)_sepia(0.15)_contrast(1.05)_brightness(0.95)] group-hover:[filter:grayscale(0)_sepia(0)_contrast(1)_brightness(1)] ${imagePosition} ${imageScale}`}
                    />
                    <div class="absolute inset-0 bg-white/15 mix-blend-screen"></div>
                  </a>
                );
              })
            }
          </div>
          <a
            href={seriesPlaylistUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group mt-4 inline-flex h-8 w-fit shrink-0 items-center gap-2 text-xs font-bold uppercase tracking-widest text-primary transition-all hover:gap-4"
          >
            Ver todas las series
            <span class="material-symbols-outlined text-base">arrow_forward</span>
          </a>
        </aside>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="py-14 md:py-12 bg-[#F8F5F0] shadow-[inset_0_6px_32px_rgba(0,0,0,0.07),inset_0_-6px_32px_rgba(0,0,0,0.04)]" id="novedades">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-8 md:mb-10">
        <div>
          <h2 class="font-display text-4xl sm:text-5xl md:text-6xl text-charcoal mb-2">Anuncios</h2>
          <p class="text-gray-500 max-w-md">Entérate de lo que está sucediendo en nuestra casa.</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-8">
        <!-- GOLD: mobile horizontal, desktop igual que serie actual -->
        <a
          data-animate="card"
          href="/ministerios/gold"
          aria-label="Ver más sobre Encuentro GOLD"
          class="md:col-span-2 group relative flex h-[130px] overflow-hidden rounded-2xl border-[12px] border-white bg-white shadow-[0_20px_40px_rgba(0,0,0,0.05),0_2px_6px_rgba(0,0,0,0.03)] transition-all duration-200 hover:-translate-y-[3px] md:flex-col md:h-[450px] md:rounded-3xl"
        >
          <!-- Imagen -->
          <div class="relative w-[48%] flex-shrink-0 overflow-hidden rounded-r-[1.25rem] md:w-full md:flex-1 md:rounded-none md:rounded-b-[1.75rem]">
            <img alt="Anuncio GOLD" class="h-full w-full object-cover object-top transition-transform duration-700 group-hover:scale-[1.02]" src="/ministries/gold/goldanuncio.jpg" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/[0.12] to-transparent"></div>
          </div>
          <!-- Mobile text -->
          <div class="flex flex-1 flex-col justify-center bg-white px-4 md:hidden">
            <span class="text-[11px] font-bold uppercase tracking-[0.12em] text-[#9ca3af]">Destacado</span>
            <h3 class="font-display text-sm font-semibold text-charcoal leading-tight">Encuentro GOLD</h3>
            <p class="text-charcoal/55 text-[11px] mt-0.5 line-clamp-2">Un tiempo especial para compartir palabra, compañerismo y crecimiento.</p>
          </div>
          <!-- Desktop text: igual que serie actual -->
          <div class="hidden md:flex flex-col justify-center bg-white flex-shrink-0 py-8 pl-8 pr-10 gap-2">
            <span class="inline-flex w-fit rounded-full bg-[#2b2b2b] px-[14px] py-[6px] text-[11px] font-bold uppercase tracking-[0.08em] text-white opacity-90">Destacado</span>
            <h3 class="font-display text-2xl font-bold text-charcoal md:text-3xl">Encuentro GOLD</h3>
            <p class="text-sm text-gray-500 line-clamp-1">Un tiempo especial para compartir palabra, compañerismo y crecimiento.</p>
          </div>
        </a>

        <!-- ARDE + Kids: horizontal siempre (como series anteriores) -->
        <div class="flex flex-col gap-4 md:gap-5 md:h-[450px]">
          <a data-animate="card" href="/ministerios/arde"
            class="group flex min-h-0 flex-1 overflow-hidden rounded-2xl border-[12px] border-white bg-white shadow-[0_20px_40px_rgba(0,0,0,0.05),0_2px_6px_rgba(0,0,0,0.03)] transition-all duration-200 hover:-translate-y-[3px] md:rounded-3xl">
            <div class="relative w-[48%] flex-shrink-0 overflow-hidden rounded-r-[1.25rem]">
              <img alt="Campamento ARDE" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" src="/ministries/arde/campaarde.jpg" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/15 to-transparent"></div>
            </div>
            <div class="flex flex-1 flex-col justify-center bg-white px-4">
              <span class="text-[11px] font-bold uppercase tracking-[0.12em] text-[#9ca3af]">Campa ARDE</span>
              <h4 class="font-display text-sm font-semibold leading-tight text-charcoal transition-colors group-hover:text-primary">Campamento ARDE</h4>
              <p class="mt-0.5 line-clamp-2 text-[11px] leading-relaxed text-gray-500">Una experiencia para adolescentes con amigos, palabra y dias que no se olvidan facil.</p>
            </div>
          </a>
          <a data-animate="card" href="/ministerios/kids"
            class="group flex min-h-0 flex-1 overflow-hidden rounded-2xl border-[12px] border-white bg-white shadow-[0_20px_40px_rgba(0,0,0,0.05),0_2px_6px_rgba(0,0,0,0.03)] transition-all duration-200 hover:-translate-y-[3px] md:rounded-3xl">
            <div class="relative w-[48%] flex-shrink-0 overflow-hidden rounded-r-[1.25rem]">
              <img alt="Campa Kids" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" src="/ministries/kids/campakids.jpg" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/15 to-transparent"></div>
            </div>
            <div class="flex flex-1 flex-col justify-center bg-white px-4">
              <span class="text-[11px] font-bold uppercase tracking-[0.12em] text-[#9ca3af]">Campa Kids</span>
              <h4 class="font-display text-sm font-semibold leading-tight text-charcoal transition-colors group-hover:text-primary">Campamento Kids</h4>
              <p class="mt-0.5 line-clamp-2 text-[11px] leading-relaxed text-gray-500">Una aventura para que los chicos aprendan, jueguen y vivan la fe con alegria.</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="py-14 md:py-16 bg-[#f3f3f3] shadow-[inset_0_6px_32px_rgba(0,0,0,0.07),inset_0_-6px_32px_rgba(0,0,0,0.04)]" id="devocional">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-10 md:mb-14">
        <div>
          <p class="mb-3 text-xs font-bold uppercase tracking-[0.24em] text-primary">Devocional</p>
          <h2 class="font-display text-3xl font-medium tracking-tight text-[#6b7280] sm:text-4xl">Devocional Actual</h2>
        </div>
      </div>
      {currentDevotionalPost && (
        <a href="/devocional" data-animate="card" class="group grid cursor-pointer grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-6 md:gap-8 items-stretch rounded-3xl border-[12px] border-white bg-white shadow-[0_20px_40px_rgba(0,0,0,0.05),0_2px_6px_rgba(0,0,0,0.03)] p-5 sm:p-6 md:p-8 transition-all duration-200 hover:-translate-y-[3px]">
          <div class="flex flex-col justify-center">
            <div class="flex flex-wrap items-center gap-3">
              <span class="text-[11px] font-bold uppercase tracking-[0.12em] text-[#9ca3af]">{currentDevotionalPost.weekLabel}</span>
              <span class="inline-flex w-fit rounded-full bg-[#2b2b2b] px-[14px] py-[6px] text-[11px] font-bold uppercase tracking-[0.08em] text-white opacity-90">Actual</span>
            </div>
            <h3 class="font-display text-3xl md:text-4xl text-charcoal mt-4 transition-colors group-hover:text-primary">{currentDevotionalPost.title}</h3>
            <p class="text-gray-600 text-sm sm:text-base mt-4 leading-relaxed">{currentDevotionalPost.excerpt}</p>
            <span class="mt-6 inline-flex h-10 w-10 items-center justify-center rounded-full border border-charcoal/20 text-charcoal transition duration-300 ease-out group-hover:-translate-y-1 group-hover:rotate-[-30deg] group-hover:border-primary group-hover:text-primary">
              <span class="material-symbols-outlined text-xl">arrow_forward</span>
            </span>
          </div>

          <div class="relative overflow-hidden rounded-2xl bg-charcoal shadow-sm lg:max-h-[320px]">
            {currentDevotionalEmbedUrl ? (
              <iframe
                class="pointer-events-none min-h-[230px] w-full aspect-video lg:h-full lg:aspect-auto"
                src={currentDevotionalEmbedUrl}
                title={currentDevotionalPost.title}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
              ></iframe>
            ) : (
              <div class="block h-full min-h-[210px]">
                <img
                  src={currentDevotionalPost.image}
                  alt={currentDevotionalPost.title}
                  class="h-full w-full object-cover translate-y-2 scale-105 transition-transform duration-500 group-hover:translate-y-2 group-hover:scale-110"
                />
              </div>
            )}
          </div>
        </a>
      )}
    </div>
  </section>

  <section data-animate="reveal" class="py-16 md:py-24 bg-white" id="ministerios">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-10 md:mb-14">
        <div>
          <p class="mb-3 text-xs font-bold uppercase tracking-[0.24em] text-primary">Ministerios</p>
          <h2 class="font-display text-3xl font-medium tracking-tight text-[#6b7280] sm:text-4xl">Nuestro Liderazgo / Ministerios</h2>
          <p class="text-gray-400 max-w-md mt-2 text-sm">Áreas donde servimos y crecemos juntos como familia.</p>
        </div>
      </div>
      <div class="flex flex-wrap justify-center gap-5 sm:gap-6 lg:gap-7">
        {
          ministries.map((ministry) => (
            <a data-animate="card" class="group flex w-[calc(50%-0.625rem)] min-w-0 max-w-[220px] flex-col items-center text-center transition-all duration-200 hover:-translate-y-[3px] md:w-[calc(33.333%-1rem)] lg:w-[calc(25%-1.1rem)] xl:w-[calc(16.666%-1.1rem)]" href={`/ministerios/${ministry.slug}`}>
              <div class={`relative overflow-hidden rounded-2xl md:rounded-[1.5rem] mb-3 md:mb-4 aspect-[4/5] sm:aspect-[3/4] w-full shadow-[0_20px_40px_rgba(0,0,0,0.05),0_2px_6px_rgba(0,0,0,0.03)] ${logoSlugs.has(ministry.slug) ? 'border-[6px] border-white bg-white p-3' : 'border-[6px] border-white'}`}>
                <img
                  alt={`Ministerio ${ministry.name}`}
                  class={`w-full h-full transition duration-500 ${logoSlugs.has(ministry.slug) ? 'object-contain' : 'object-cover group-hover:scale-105'}`}
                  src={ministry.image}
                />
                <div class={`absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4 ${logoSlugs.has(ministry.slug) ? 'bg-gradient-to-t from-charcoal/45 to-transparent' : 'bg-gradient-to-t from-charcoal/80 to-transparent'}`}>
                  <span class="text-white text-xs font-bold uppercase tracking-wider">Ver ministerio</span>
                </div>
              </div>
              <h3 class="font-display text-base sm:text-lg text-charcoal group-hover:text-primary transition-colors">{ministry.name}</h3>
              <p class="text-[11px] font-bold uppercase tracking-[0.12em] text-[#9ca3af] mt-1">{ministry.area}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="py-14 md:py-12 bg-white" id="radio">
    <div class="mx-auto max-w-[90rem] px-5 sm:px-6 lg:px-8">
      <div class="bg-charcoal rounded-2xl md:rounded-3xl p-6 sm:p-8 md:p-16 flex flex-col md:flex-row items-center justify-between relative overflow-hidden">
        <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
        <div class="flex items-center gap-4 sm:gap-6 relative z-10">
