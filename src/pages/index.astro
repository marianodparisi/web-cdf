                <div class="absolute left-4 bottom-4 flex items-center gap-2">
                  <span class="inline-flex rounded-full bg-primary px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold">{mission.stage}</span>
                  <span class="inline-flex rounded-full bg-white/90 px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold">{mission.country}</span>
                </div>
              </div>
              <div class="p-5">
                <h3 class="font-display text-2xl text-charcoal">{mission.place}</h3>
                <p class="text-gray-600 text-sm mt-2 leading-relaxed">{mission.summary}</p>
              </div>
            </article>
          ))
        }
      </div>
      <div class="md:hidden mt-6">
        <a class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-charcoal border-b border-charcoal pb-1 hover:text-primary hover:border-primary transition-colors" href="/misiones">
          Ver todas
          <span class="material-symbols-outlined text-sm">arrow_outward</span>
        </a>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="py-16 md:py-24 bg-gray-50" id="ministerios">
