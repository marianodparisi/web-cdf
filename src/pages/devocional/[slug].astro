---
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Navbar.astro';
import { devotionalPosts, type DevotionalPost } from '../../data/devotionals';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return devotionalPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: DevotionalPost;
}

const { post } = Astro.props as Props;
const relatedPosts = devotionalPosts.filter((item) => item.slug !== post.slug).slice(0, 3);
const pageTitle = `${post.title} | Devocional CDF`;
---

<BaseLayout title={pageTitle}>
  <Navbar />

  <section data-animate="reveal" class="bg-charcoal text-white pt-14 md:pt-20 pb-10 md:pb-14">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
      <a href="/devocional" class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-white/75 hover:text-primary transition-colors">
        <span class="material-symbols-outlined text-sm">arrow_back</span>
        Volver a devocional
      </a>

      <div class="mt-6 md:mt-8 grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10 items-stretch">
        <div data-animate="card" class="relative rounded-3xl overflow-hidden min-h-[320px] sm:min-h-[380px] md:min-h-[460px]">
          <img src={post.image} alt={post.title} class="absolute inset-0 h-full w-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/50 to-transparent"></div>
          <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8">
            <div class="flex items-center gap-2">
              <span class="inline-flex rounded-full bg-primary px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold">{post.type}</span>
              {post.videoUrl && (
                <span class="inline-flex rounded-full bg-white/90 px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold">Video</span>
              )}
            </div>
            <h1 class="font-display text-3xl sm:text-5xl mt-3 leading-tight">{post.title}</h1>
          </div>
        </div>

        <div data-animate="card" class="rounded-3xl bg-white/5 border border-white/10 backdrop-blur-sm p-6 sm:p-8 md:p-10 flex flex-col justify-between">
          <div>
            <p class="text-primary text-xs uppercase tracking-[0.2em] font-semibold mb-3">{post.weekLabel}</p>
            <p class="text-white/90 text-sm sm:text-base leading-relaxed">{post.excerpt}</p>
            <div class="mt-5 space-y-4">
              {
                post.content.map((paragraph) => (
                  <p class="text-white/80 text-sm sm:text-base leading-relaxed">{paragraph}</p>
                ))
              }
            </div>
          </div>
          {post.videoUrl && (
            <a
              href={post.videoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-8 inline-flex w-fit items-center gap-2 rounded-full bg-primary px-6 py-3 text-[11px] uppercase tracking-[0.18em] text-charcoal font-semibold hover:bg-white transition-colors"
            >
              Ver video
              <span class="material-symbols-outlined text-base">arrow_outward</span>
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="pb-14 md:pb-16 pt-12 bg-white">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-display text-2xl sm:text-3xl text-charcoal">Mas contenido semanal</h2>
        <a href="/devocional" class="text-xs uppercase tracking-[0.18em] text-charcoal hover:text-primary transition-colors">Ver todos</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-5">
        {
          relatedPosts.map((item) => (
            <a data-animate="card" href={`/devocional/${item.slug}`} class="group rounded-2xl overflow-hidden border border-gray-200 bg-white hover:border-primary/60 transition-colors">
              <div class="relative h-40 sm:h-44">
                <img src={item.image} alt={item.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
              </div>
              <div class="p-4">
                <p class="text-[10px] uppercase tracking-[0.18em] text-gray-500">{item.weekLabel}</p>
                <h3 class="font-display text-lg text-charcoal group-hover:text-primary transition-colors mt-1">{item.title}</h3>
                <p class="text-xs uppercase tracking-widest text-gray-500 mt-2">{item.type}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
