---
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Navbar.astro';
import { devotionalPosts } from '../../data/devotionals';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Devocional y Testimonios | Iglesia Corazon de Fuego">
  <Navbar />

  <section data-animate="reveal" class="pt-14 md:pt-20 pb-8 md:pb-10 bg-white">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
      <span class="text-primary text-xs uppercase tracking-[0.22em] font-semibold">Contenido semanal</span>
      <h1 class="font-display text-4xl sm:text-5xl text-charcoal mt-2">Devocional Diario / Testimonios</h1>
      <p class="text-gray-500 mt-4 max-w-2xl">
        Palabras breves, testimonios y videos para fortalecer tu semana. Aqui vas a encontrar todo el contenido completo.
      </p>
    </div>
  </section>

  <section data-animate="reveal" class="pb-14 md:pb-16 bg-white">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6">
        {
          devotionalPosts.map((post) => (
            <article data-animate="card" class="rounded-3xl overflow-hidden border border-gray-200 bg-white">
              <a href={`/devocional/${post.slug}`} class="group block">
                <div class="relative h-56 sm:h-64">
                  <img src={post.image} alt={post.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/55 to-transparent"></div>
                  <div class="absolute left-4 bottom-4 flex items-center gap-2">
                    <span class="inline-flex rounded-full bg-primary px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold">{post.type}</span>
                    {post.videoUrl && (
                      <span class="inline-flex rounded-full bg-white/90 px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold">Video</span>
                    )}
                  </div>
                </div>
              </a>
              <div class="p-5 sm:p-6">
                <p class="text-xs uppercase tracking-[0.2em] text-gray-500">{post.weekLabel}</p>
                <h2 class="font-display text-2xl text-charcoal mt-2">{post.title}</h2>
                <p class="text-gray-600 text-sm mt-3 leading-relaxed">{post.excerpt}</p>
                <a href={`/devocional/${post.slug}`} class="mt-5 inline-flex items-center gap-2 text-xs uppercase tracking-[0.18em] text-charcoal hover:text-primary transition-colors">
                  Ver completo
                  <span class="material-symbols-outlined text-sm">arrow_outward</span>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
