---
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Navbar.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Arde | Iglesia Corazon de Fuego">
  <Navbar sticky={false} />

  <header class="arde-panel px-6 md:px-12 pt-7 pb-10 grid grid-cols-12 gap-8 lg:items-start lg:pt-16 bg-gradient-to-br from-white via-orange-100 to-amber-100/80 relative overflow-hidden">
    <div class="hero-glow"></div>
    <div class="col-span-12 lg:col-span-5">
      <img alt="ARDE Logo" class="w-24 h-auto mb-6" src="/arde.png" />
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold leading-[1.1] mb-6 font-['Poppins']">
        <span class="text-arde-orange">Reunion de <br /> Adolescentes.</span>
      </h1>
      <p class="text-gray-500 text-lg mb-8 max-w-md leading-relaxed font-['Poppins']">
        Somos una comunidad donde adolescentes descubren su identidad, construyen amistades reales y viven su fe con pasion.
      </p>
      <div class="flex flex-wrap gap-2 sm:gap-3 max-w-md min-w-0">
        <div class="px-4 sm:px-6 py-2 sm:py-3 pill-capsule font-medium border border-gray-200 text-sm sm:text-base">Amistad Real</div>
        <div class="px-4 sm:px-6 py-2 sm:py-3 pill-capsule font-medium border border-gray-200 text-sm sm:text-base">Eventos Epicos</div>
        <div class="px-4 sm:px-6 py-2 sm:py-3 pill-capsule font-medium bg-[#D1FAE5] text-green-800 border border-green-200 text-sm sm:text-base">Mentoria</div>
        <div class="px-4 sm:px-6 py-2 sm:py-3 pill-capsule font-medium border border-gray-200 text-sm sm:text-base">Musica</div>
      </div>
    </div>

    <div class="col-span-12 lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 relative">
      <div class="sm:hidden mt-6 flex justify-center items-center gap-2 h-64 overflow-visible order-1">
        <div class="w-1/3 h-full organic-card bg-cover bg-center -rotate-6 shadow-xl border-4 border-white" style="background-image: url('/ardehero.png');"></div>
        <div class="w-2/5 h-[110%] organic-card bg-arde-yellow flex flex-col justify-center p-4 z-10 shadow-2xl border-4 border-white text-arde-orange">
          <span class="font-semibold text-xs opacity-90">Proximo Evento</span>
          <span class="text-[10px] font-bold">Sab 18:00</span>
        </div>
        <a href="https://www.instagram.com/p/DUvsY8Bjlwk/" target="_blank" rel="noopener noreferrer" class="w-1/3 h-full organic-card overflow-hidden rotate-6 shadow-xl border-4 border-white block">
          <img alt="Serie" class="w-full h-full object-cover" src="/serie.png" />
        </a>
      </div>

      <div class="hidden sm:block hero-card relative bg-gray-200 asymmetric-grid-item overflow-hidden h-[400px] lg:h-[500px] mt-12 order-1">
        <img alt="Featured Member" class="hero-card-img w-full h-full object-cover" src="/ardehero.png" />
      </div>

      <div class="hidden sm:flex flex-col scale-90 gap-6 order-2">
        <div class="hero-card bg-arde-yellow p-5 sm:p-8 asymmetric-grid-item text-arde-orange h-[180px] sm:h-[220px] flex flex-col justify-center">
          <div class="flex justify-between items-center mb-6">
            <span class="font-semibold opacity-90">Proximo Evento</span>
            <span class="bg-white/20 px-3 py-1 rounded-full text-xs font-bold">Sab 18:00</span>
          </div>
          <div class="flex items-end gap-2 h-20 mb-6">
            <div class="w-8 bg-white/40 rounded-lg h-1/2"></div>
            <div class="w-8 bg-white/40 rounded-lg h-3/4"></div>
            <div class="w-8 bg-white rounded-lg h-full"></div>
            <div class="w-8 bg-white/40 rounded-lg h-2/3"></div>
          </div>
          <div class="flex justify-between text-sm font-medium">
            <span>Actividad de adolescentes</span>
            <span>Sede Gaona</span>
          </div>
        </div>

        <a href="https://www.instagram.com/p/DUvsY8Bjlwk/" target="_blank" rel="noopener noreferrer" class="hero-card asymmetric-grid-item overflow-hidden h-auto relative sm:scale-75 sm:origin-top block">
          <img alt="Serie" class="w-full h-auto" src="/serie.png" />
        </a>
      </div>
    </div>
  </header>

  <section class="arde-panel px-6 sm:px-12 py-8 sm:py-12 bg-white">
    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-6 sm:gap-8 items-stretch">
      <div class="relative overflow-hidden asymmetric-grid-item min-h-[320px] sm:min-h-[420px] shadow-[0_24px_60px_-30px_rgba(17,24,39,0.45)]">
        <img alt="Campamento ARDE para adolescentes" class="w-full h-full object-cover" src="/campaarde.jpg" />
        <div class="absolute inset-0 bg-gradient-to-t from-arde-dark via-arde-dark/35 to-transparent"></div>
        <div class="absolute left-5 right-5 bottom-5 sm:left-8 sm:right-8 sm:bottom-8 text-white">
          <span class="inline-flex rounded-full bg-white/15 backdrop-blur px-3 py-1 text-[11px] uppercase tracking-[0.24em] font-semibold">Campa ARDE</span>
          <p class="mt-3 max-w-md text-sm sm:text-base text-white/85">
            Una experiencia para adolescentes con amigos, palabra, juegos y dias que no se olvidan facil.
          </p>
        </div>
      </div>

      <div class="bg-[#fff5ef] border border-[#f3c6b5] asymmetric-grid-item p-6 sm:p-10 flex flex-col justify-center">
        <span class="text-arde-orange text-xs sm:text-sm uppercase tracking-[0.24em] font-bold">Especial para adolescentes</span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold mt-3 mb-4 text-arde-dark leading-tight font-['Poppins']">
          Se viene el campamento de ARDE
        </h2>
        <p class="text-gray-600 text-base sm:text-lg leading-relaxed mb-6">
          Si formas parte de ARDE, este campa es para vos. Un tiempo para desconectarte de lo de siempre, encontrar a Dios de una forma real y vivir algo fuerte con tu grupo.
        </p>
        <div class="flex flex-wrap gap-3 mb-8">
          <span class="px-4 py-2 rounded-full bg-white text-arde-dark font-semibold border border-[#f3c6b5]">Adolescentes 11 a 18</span>
          <span class="px-4 py-2 rounded-full bg-white text-arde-dark font-semibold border border-[#f3c6b5]">Amigos + fe + diversion</span>
        </div>
        <a href="https://maps.app.goo.gl/nbkxbz89Rt92Aqx78" target="_blank" rel="noopener noreferrer" class="inline-flex w-fit items-center justify-center bg-arde-orange text-white px-7 sm:px-9 py-4 pill-capsule font-bold text-base sm:text-lg shadow-[0_18px_40px_-18px_rgba(232,93,53,0.9)]">
          Quiero info del campa
        </a>
      </div>
    </div>
  </section>

  <section class="arde-panel px-6 sm:px-12 py-8 sm:py-12 min-h-0 flex flex-col md:flex-row gap-6 sm:gap-8 items-stretch md:items-center">
    <div class="flex-1 border-4 border-arde-dark p-6 sm:p-12 asymmetric-grid-item">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold mb-6 sm:mb-8 font-['Poppins']">Horarios</h2>
      <ul class="space-y-6">
        <li class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-1 border-b border-gray-100 pb-4">
          <span class="font-bold text-lg sm:text-xl text-arde-orange">Sabados</span>
          <span class="text-gray-500 text-base sm:text-lg">18:00 - 20:00 hs</span>
        </li>
        <li class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-1 border-b border-gray-100 pb-4">
          <span class="font-bold text-lg sm:text-xl">Edad</span>
          <span class="text-gray-500 text-base sm:text-lg">11 a 18 anos</span>
        </li>
      </ul>
    </div>
    <div class="flex-1 bg-arde-orange p-6 sm:p-12 asymmetric-grid-item text-white flex flex-col justify-between">
      <div>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold mb-4 font-['Poppins']">Ubicacion</h2>
        <p class="text-base sm:text-xl opacity-90 leading-relaxed mb-6 sm:mb-8">
          Av. Pres. Peron 251 <br />
          B1706 Villa Sarmiento, Provincia de Buenos Aires
        </p>
      </div>
      <a href="https://maps.app.goo.gl/nbkxbz89Rt92Aqx78" target="_blank" rel="noopener noreferrer" class="bg-white text-arde-dark px-8 sm:px-10 py-4 sm:py-5 pill-capsule font-bold text-base sm:text-lg text-center">
        Ver en Google Maps
      </a>
    </div>
  </section>

  <section class="arde-panel mx-4 sm:mx-6 md:mx-12 mb-12">
    <div class="relative overflow-hidden text-white p-8 sm:p-12 md:p-16 lg:p-24 asymmetric-grid-item text-center cta-parallax">
      <div class="absolute inset-0 bg-[rgba(17,24,39,0.6)]"></div>
      <div class="relative z-10">
        <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-7xl font-extrabold mb-6 sm:mb-8 max-w-4xl mx-auto leading-tight font-['Poppins']">
          Listo para encender tu pasion?
        </h2>
        <p class="text-base sm:text-lg md:text-xl text-gray-300 mb-8 sm:mb-12 max-w-2xl mx-auto">
          No importa de donde vengas o en que creas, aqui siempre hay un lugar para ti.
        </p>
        <a href="https://maps.app.goo.gl/nbkxbz89Rt92Aqx78" target="_blank" rel="noopener noreferrer" class="bg-white text-arde-dark text-base sm:text-xl px-8 sm:px-12 py-5 sm:py-6 pill-capsule font-bold inline-block">
          Quiero ser parte ahora
        </a>
      </div>
    </div>
  </section>

  <style>
    .arde-panel {
      font-family: 'Poppins', sans-serif;
    }
    .text-arde-orange { color: #e85d35; }
    .bg-arde-orange { background-color: #e85d35; }
    .text-arde-dark { color: #111827; }
    .bg-arde-dark { background-color: #111827; }
    .bg-arde-yellow { background-color: #ffd744; }

    .pill-capsule {
      border-radius: 9999px;
    }
    .asymmetric-grid-item {
      border-radius: 1.5rem;
    }
    @media (min-width: 640px) {
      .asymmetric-grid-item {
        border-radius: 2.5rem;
      }
    }
    @media (min-width: 1024px) {
      .asymmetric-grid-item {
        border-radius: 3.5rem;
      }
    }
    .hero-glow {
      position: absolute;
      top: 20%;
      right: -5%;
      width: 60%;
      height: 80%;
      background: radial-gradient(ellipse at center, rgba(232, 93, 53, 0.12) 0%, rgba(255, 215, 68, 0.08) 40%, transparent 70%);
      filter: blur(60px);
      pointer-events: none;
      z-index: 0;
    }
    .hero-card {
      transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.35s ease;
      box-shadow: 0 8px 30px -8px rgba(0, 0, 0, 0.1), 0 2px 8px -2px rgba(0, 0, 0, 0.06);
    }
    .hero-card:hover {
      transform: scale(1.04) translateY(-4px);
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.2), 0 10px 20px -5px rgba(232, 93, 53, 0.1);
    }
    .organic-card {
      border-radius: 1rem 1rem 2rem 2rem;
      overflow: hidden;
    }
    .cta-parallax {
      background-image: url('/arde1.png');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }
  </style>

  <Footer />
</BaseLayout>
