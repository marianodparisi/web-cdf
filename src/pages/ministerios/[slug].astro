---
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Navbar.astro';
import { ministries, type Ministry } from '../../data/ministries';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return ministries.map((ministry) => ({
    params: { slug: ministry.slug },
    props: { ministry },
  }));
}

interface Props {
  ministry: Ministry;
}

const { ministry } = Astro.props as Props;
const relatedMinistries = ministries.filter((item) => item.slug !== ministry.slug).slice(0, 3);
const pageTitle = `Ministerio ${ministry.name} | Iglesia Corazon de Fuego`;
---

<BaseLayout title={pageTitle}>
  <Navbar />

  <section data-animate="reveal" class="bg-charcoal text-white pt-14 md:pt-20 pb-10 md:pb-14">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
      <a href="/#ministerios" class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-white/75 hover:text-primary transition-colors">
        <span class="material-symbols-outlined text-sm">arrow_back</span>
        Volver a ministerios
      </a>

      <div class="mt-6 md:mt-8 grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10 items-stretch">
        <div data-animate="card" class="relative rounded-3xl overflow-hidden min-h-[320px] sm:min-h-[380px] md:min-h-[460px]">
          <img src={ministry.image} alt={`Ministerio ${ministry.name}`} class="absolute inset-0 h-full w-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/50 to-transparent"></div>
          <div class="absolute inset-x-0 bottom-0 p-6 sm:p-8">
            <span class="inline-flex rounded-full bg-primary px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold">{ministry.area}</span>
            <h1 class="font-display text-4xl sm:text-5xl md:text-6xl mt-3 leading-tight lowercase">{ministry.name}</h1>
          </div>
        </div>

        <div data-animate="card" class="rounded-3xl bg-white/5 border border-white/10 backdrop-blur-sm p-6 sm:p-8 md:p-10 flex flex-col justify-between">
          <div>
            <p class="text-primary text-xs uppercase tracking-[0.2em] font-semibold mb-3">Descripcion</p>
            <p class="text-white/90 text-sm sm:text-base leading-relaxed">{ministry.description}</p>
            <p class="mt-5 text-white/75 text-sm sm:text-base leading-relaxed">{ministry.excerpt}</p>
          </div>
          <a href="/contact" class="mt-8 inline-flex w-fit items-center gap-2 rounded-full bg-primary px-6 py-3 text-[11px] uppercase tracking-[0.18em] text-charcoal font-semibold hover:bg-white transition-colors">
            Quiero sumarme
            <span class="material-symbols-outlined text-base">arrow_outward</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="py-14 md:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-8">
        <article data-animate="card" class="rounded-3xl border border-gray-200 bg-gray-50 p-6 sm:p-8">
          <p class="text-primary text-xs uppercase tracking-[0.2em] font-semibold mb-2">Como participar</p>
          <p class="text-charcoal text-sm sm:text-base leading-relaxed">{ministry.participation}</p>
        </article>
        <article data-animate="card" class="rounded-3xl border border-gray-200 bg-gray-50 p-6 sm:p-8">
          <p class="text-primary text-xs uppercase tracking-[0.2em] font-semibold mb-2">Ritmo de reuniones</p>
          <p class="text-charcoal text-sm sm:text-base leading-relaxed">{ministry.schedule}</p>
        </article>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="pb-14 md:pb-16 bg-white">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-display text-2xl sm:text-3xl text-charcoal">Otros ministerios</h2>
        <a href="/#ministerios" class="text-xs uppercase tracking-[0.18em] text-charcoal hover:text-primary transition-colors">Ver todos</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-5">
        {
          relatedMinistries.map((item) => (
            <a data-animate="card" href={`/ministerios/${item.slug}`} class="group rounded-2xl overflow-hidden border border-gray-200 bg-white hover:border-primary/60 transition-colors">
              <div class="relative h-40 sm:h-44">
                <img src={item.image} alt={`Ministerio ${item.name}`} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
              </div>
              <div class="p-4">
                <h3 class="font-display text-lg text-charcoal group-hover:text-primary transition-colors">{item.name}</h3>
                <p class="text-xs uppercase tracking-widest text-gray-500 mt-1">{item.area}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
