---
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Navbar.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Life | Iglesia Corazón de Fuego">
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
    />
  </Fragment>

  <div class="bg-[#fff8f6] text-[#2c160e] [font-family:'Plus_Jakarta_Sans',sans-serif]">
    <Navbar sticky={false} />

    <main class="relative overflow-hidden">
      <section class="relative flex min-h-[calc(100vh-5rem)] items-center justify-center overflow-hidden px-6 py-12 md:py-24">
        <div class="absolute inset-0">
          <div class="absolute inset-0 bg-gradient-to-b from-black/45 via-black/20 to-[#fff8f6]"></div>
          <div class="h-full w-full bg-cover bg-center" style="background-image: url('/life3.jpg');"></div>
        </div>

        <div class="relative z-10 mx-auto max-w-5xl text-center">
          <div class="mb-8 inline-block rounded-2xl bg-white/90 p-4 shadow-[0_24px_48px_-12px_rgba(44,22,14,0.12)] backdrop-blur-md">
            <img src="/life.png" alt="Logo LIFE" class="h-20 w-auto object-contain" />
          </div>

          <h1 class="mb-6 text-4xl font-extrabold leading-tight tracking-tight text-white md:text-6xl lg:text-7xl">
            Bienvenidos a LIFE:
            <br />
            <span class="bg-gradient-to-r from-[#ffb59a] via-[#ffba38] to-[#ffdad5] bg-clip-text text-transparent">
              Edificando Matrimonios con Propósito
            </span>
          </h1>

          <p class="mx-auto mb-10 max-w-2xl text-lg font-medium leading-relaxed text-white/90 md:text-xl">
            Un espacio vibrante para crecer juntos en amor, fe y comunidad.
          </p>

          <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href="#contacto"
              class="rounded-2xl bg-gradient-to-br from-[#7d0004] to-[#a60f0f] px-8 py-4 text-lg font-bold text-white shadow-[0_24px_48px_-12px_rgba(44,22,14,0.2)] transition-transform hover:scale-105"
            >
              Únete a nosotros
            </a>
            <a
              href="#quienes-somos"
              class="rounded-2xl border border-white/20 bg-white/10 px-8 py-4 text-lg font-bold text-white backdrop-blur-sm transition-colors hover:bg-white/20"
            >
              Conoce más
            </a>
          </div>
        </div>

        <div class="absolute bottom-8 left-1/2 z-10 flex -translate-x-1/2 flex-col items-center gap-2 text-white/60">
          <span class="text-xs font-bold uppercase tracking-widest">Descubrir</span>
          <span class="material-symbols-outlined animate-bounce">expand_more</span>
        </div>
      </section>

      <section id="quienes-somos" class="bg-[#fff8f6] px-6 py-24 md:px-12">
        <div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-16 lg:grid-cols-2">
          <div class="relative">
            <div class="absolute -left-12 -top-12 h-48 w-48 rounded-full bg-[#fc6018]/10 blur-3xl"></div>
            <div class="relative z-10 overflow-hidden rounded-[1.75rem] shadow-[0_24px_48px_-12px_rgba(44,22,14,0.08)] -rotate-2">
              <img src="/life2.jpeg" alt="Grupo LIFE reunido en una mesa" class="aspect-[4/5] w-full object-cover" />
            </div>
            <div class="absolute -bottom-8 -right-8 h-64 w-64 rounded-full bg-[#7d0004]/10 blur-3xl"></div>
          </div>

          <div class="flex flex-col gap-6">
            <span class="text-sm font-bold uppercase tracking-widest text-[#a83900]">Nuestra Comunidad</span>
            <h2 class="text-4xl font-extrabold leading-tight text-[#2c160e] md:text-5xl">¿Quiénes Somos?</h2>
            <p class="text-xl leading-relaxed text-[#5b403d]">
              LIFE es una comunidad vibrante diseñada específicamente para matrimonios jóvenes que buscan
              fortalecer su relación y crecer en su caminar espiritual. Creemos que el matrimonio es un viaje
              emocionante que se vive mejor en compañía.
            </p>

            <div class="mt-4 grid grid-cols-1 gap-6 md:grid-cols-2">
              <div class="flex flex-col gap-3 rounded-2xl bg-[#fff1ed] p-6">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#7d0004] text-white">
                  <span class="material-symbols-outlined">groups</span>
                </div>
                <h3 class="text-lg font-bold text-[#2c160e]">Apoyo Mutuo</h3>
                <p class="text-sm leading-normal text-[#5b403d]">
                  Caminamos juntos compartiendo victorias y retos cotidianos.
                </p>
              </div>

              <div class="flex flex-col gap-3 rounded-2xl bg-[#fff1ed] p-6">
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[#ffdeac] text-[#6f4c00]">
                  <span class="material-symbols-outlined">auto_stories</span>
                </div>
                <h3 class="text-lg font-bold text-[#2c160e]">Base Bíblica</h3>
                <p class="text-sm leading-normal text-[#5b403d]">
                  Edificamos sobre la Roca con enseñanzas aplicables al hoy.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="cuando-nos-reunimos" class="bg-[#fff1ed] px-6 py-24 md:px-12">
        <div class="mx-auto mb-16 max-w-5xl text-center">
          <span class="text-sm font-bold uppercase tracking-widest text-[#a83900]">Nuestro Ritmo</span>
          <h2 class="mt-4 text-4xl font-extrabold text-[#2c160e] md:text-5xl">¿Cuándo nos reunimos?</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-[#5b403d]">
            Nuestras reuniones son el corazón de LIFE. Nos enfocamos en crear un ambiente relajado donde la
            conexión sea lo primero.
          </p>
        </div>

        <div class="mx-auto max-w-7xl">
          <div class="overflow-hidden rounded-[1.75rem] bg-white shadow-[0_24px_48px_-12px_rgba(44,22,14,0.08)] lg:flex">
            <div class="flex flex-1 flex-col justify-center gap-8 p-10 lg:p-16">
              <div class="flex items-start gap-6">
                <div class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-2xl bg-[#a83900]/10 text-[#a83900]">
                  <span class="material-symbols-outlined text-3xl">calendar_today</span>
                </div>
                <div>
                  <h4 class="mb-2 text-xl font-bold text-[#2c160e]">Reuniones Semanales</h4>
                  <p class="text-[#5b403d]">
                    Cada viernes a las 7:30 PM. Alternamos entre estudios bíblicos, cenas en casas y actividades
                    recreativas.
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-6">
                <div class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-2xl bg-[#ffba38]/25 text-[#513700]">
                  <span class="material-symbols-outlined text-3xl">location_on</span>
                </div>
                <div>
                  <h4 class="mb-2 text-xl font-bold text-[#2c160e]">Ubicación Flexible</h4>
                  <p class="text-[#5b403d]">
                    Nos gusta la variedad. A veces en el salón parroquial, a veces en el hogar de una pareja
                    anfitriona.
                  </p>
                </div>
              </div>

              <div class="pt-6">
                <a href="/calendario" class="inline-flex items-center gap-2 font-bold text-[#7d0004] transition-all hover:gap-4">
                  Ver el calendario completo
                  <span class="material-symbols-outlined">arrow_forward</span>
                </a>
              </div>
            </div>

            <div class="min-h-[400px] flex-1">
              <div class="h-full w-full bg-cover bg-center" style="background-image: url('/life1.jpg');"></div>
            </div>
          </div>
        </div>
      </section>

      <section id="para-quien-es" class="bg-[#fff8f6] px-6 py-24 md:px-12">
        <div class="mx-auto flex max-w-7xl flex-col gap-16 lg:flex-row-reverse lg:items-center">
          <div class="lg:w-1/2">
            <div class="relative">
              <div class="absolute -inset-4 rotate-3 rounded-[1.75rem] bg-[#a60f0f]/5"></div>
              <img
                src="/life4.jpeg"
                alt="Pareja caminando tomada de la mano"
                class="relative z-10 h-auto w-full rounded-[1.75rem] object-cover shadow-[0_24px_48px_-12px_rgba(44,22,14,0.08)]"
              />
            </div>
          </div>

          <div class="flex flex-col gap-8 lg:w-1/2">
            <span class="text-sm font-bold uppercase tracking-widest text-[#a83900]">Tu Lugar</span>
            <h2 class="text-4xl font-extrabold text-[#2c160e] md:text-5xl">¿Para quién es?</h2>
            <p class="text-xl leading-relaxed text-[#5b403d]">
              Este grupo es ideal para parejas que están comenzando su viaje juntas y desean construir una base
              espiritual sólida desde el principio.
            </p>

            <ul class="space-y-4">
              <li class="flex items-center gap-4 font-medium text-[#2c160e]">
                <span class="material-symbols-outlined text-[#a83900]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                Recién casados (0-10 años)
              </li>
              <li class="flex items-center gap-4 font-medium text-[#2c160e]">
                <span class="material-symbols-outlined text-[#a83900]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                Parejas con o sin hijos pequeños
              </li>
              <li class="flex items-center gap-4 font-medium text-[#2c160e]">
                <span class="material-symbols-outlined text-[#a83900]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                Quienes buscan amistades con valores similares
              </li>
              <li class="flex items-center gap-4 font-medium text-[#2c160e]">
                <span class="material-symbols-outlined text-[#a83900]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                Cualquiera que desee un matrimonio con propósito
              </li>
            </ul>

            <div class="mt-4 rounded-2xl border-l-4 border-[#7d0004] bg-[#ffe9e3] p-8">
              <p class="text-lg italic text-[#5b403d]">
                "En LIFE encontramos no solo amigos, sino una familia que nos ayudó a entender el diseño de Dios
                para nuestra unión."
              </p>
              <p class="mt-4 font-bold text-[#2c160e]">— Marcos y Elena, miembros desde 2022</p>
            </div>
          </div>
        </div>
      </section>

      <section id="contacto" class="overflow-hidden bg-[#fff8f6] px-6 py-24 md:px-12">
        <div class="relative mx-auto max-w-4xl">
          <div class="absolute left-1/2 top-0 -z-10 h-full w-[120%] -translate-x-1/2 rounded-[4rem] bg-gradient-to-br from-[#a60f0f] via-[#7d0004] to-[#fc6018] opacity-10 blur-3xl"></div>
          <div class="flex flex-col items-center gap-8 rounded-[2rem] border border-[#e4beb9]/40 bg-[#ffdbd0]/35 p-12 text-center shadow-[0_24px_48px_-12px_rgba(44,22,14,0.08)] backdrop-blur-sm md:p-20">
            <h2 class="text-4xl font-black leading-tight text-[#2c160e] md:text-5xl">¿Listos para empezar este viaje?</h2>
            <p class="max-w-xl text-xl text-[#5b403d]">
              No importa en qué etapa de su matrimonio se encuentren, siempre hay espacio para crecer. ¡Vengan a
              conocernos este viernes!
            </p>

            <div class="flex w-full flex-col justify-center gap-4 sm:flex-row">
              <a
                href="mailto:info@corazondefuego.com"
                class="flex items-center justify-center gap-2 rounded-2xl bg-[#7d0004] px-10 py-5 text-xl font-bold text-white shadow-xl transition-colors hover:bg-[#930006]"
              >
                <span class="material-symbols-outlined">mail</span>
                Escríbenos
              </a>
              <a
                href="https://wa.me/"
                class="flex items-center justify-center gap-2 rounded-2xl border border-[#e4beb9] bg-white px-10 py-5 text-xl font-bold text-[#2c160e] shadow-lg transition-colors hover:bg-[#fff1ed]"
              >
                <span class="material-symbols-outlined text-[#25D366]">chat</span>
                WhatsApp
              </a>
            </div>

            <div class="flex flex-col gap-2 pt-4">
              <p class="text-sm font-bold uppercase tracking-tight text-[#a83900]">Síguenos en redes</p>
              <div class="flex justify-center gap-4">
                <a
                  href="https://www.instagram.com/corazondefuegoiglesia/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex h-10 w-10 items-center justify-center rounded-full bg-[#ffe2da] text-[#2c160e] transition-all hover:bg-[#7d0004] hover:text-white"
                  aria-label="Instagram"
                >
                  <span class="material-symbols-outlined">photo_camera</span>
                </a>
                <a
                  href="https://www.facebook.com/corazondefuegoiglesia/?locale=es_LA"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex h-10 w-10 items-center justify-center rounded-full bg-[#ffe2da] text-[#2c160e] transition-all hover:bg-[#7d0004] hover:text-white"
                  aria-label="Facebook"
                >
                  <span class="material-symbols-outlined">social_leaderboard</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
