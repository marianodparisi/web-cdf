---
import AnexoTemplate from '../../components/AnexoTemplate.astro';
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Navbar.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Anexo Palito | Iglesia Corazon de Fuego">
  <Navbar />
  <AnexoTemplate
    title="Palito"
    subtitle="Plantilla inicial del anexo para ir sumando informacion de la sede."
    intro="Base para presentar actividades, comunidad y avance de la obra en Palito."
    locationText="Seccion placeholder para direccion y referencias de llegada."
    meetingsText="Seccion placeholder para horarios de reuniones y encuentros."
    teamText="Seccion placeholder para responsables y canales de comunicacion."
    themeClass="bg-[#2a2214]"
  />
  <Footer />
</BaseLayout>
