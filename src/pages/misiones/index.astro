---
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Navbar.astro';
import { missions } from '../../data/missions';
import BaseLayout from '../../layouts/BaseLayout.astro';

const missionsChronological = [...missions].sort((a, b) => new Date(b.startDate).getTime() - new Date(a.startDate).getTime());

const dateFormatter = new Intl.DateTimeFormat('es-AR', {
  month: 'long',
  year: 'numeric',
});

const getLocalMissionDate = (date: string) => new Date(`${date}T12:00:00`);
---

<BaseLayout title="Misiones | Iglesia Corazon de Fuego">
  <Navbar />

  <section data-animate="reveal" class="pt-16 md:pt-24 pb-12 md:pb-16 bg-white">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
        <div>
          <span class="text-primary text-xs uppercase tracking-[0.22em] font-semibold">Misiones</span>
          <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl text-charcoal mt-3 leading-[1.02]">
            Alcanzar, servir y llevar el mensaje de Jesús.
          </h1>
        </div>
        <div class="space-y-5 text-base leading-relaxed text-gray-600 sm:text-lg">
          <p>
            Misiones expresa el corazón evangelístico de la iglesia: salir de nuestra comodidad para acompañar, predicar, servir y fortalecer personas, familias y comunidades.
          </p>
          <p>
            Cada destino representa una respuesta concreta al llamado de Dios. Oramos, preparamos equipos y caminamos con iglesias locales para que el amor de Cristo llegue a más lugares.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="pb-10 md:pb-14 bg-white">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6">
        <article data-animate="card" class="rounded-3xl border border-gray-200 bg-gray-50 p-6 sm:p-8">
          <p class="text-primary text-xs uppercase tracking-[0.2em] font-semibold">Propósito</p>
          <h2 class="font-display text-3xl text-charcoal mt-4">Una iglesia en movimiento.</h2>
          <p class="text-gray-600 text-sm mt-4 leading-relaxed">
            Creemos que la misión nace en la adoración y se expresa en servicio. Por eso formamos equipos que anuncian el evangelio, acompañan procesos y responden a necesidades reales.
          </p>
        </article>
        <article data-animate="card" class="rounded-3xl border border-gray-200 bg-white p-6 sm:p-8">
          <p class="text-primary text-xs uppercase tracking-[0.2em] font-semibold">Equipo</p>
          <h2 class="font-display text-3xl text-charcoal mt-4">Servimos juntos.</h2>
          <p class="text-gray-600 text-sm mt-4 leading-relaxed">
            Cada salida se sostiene con oración, preparación, generosidad y personas dispuestas a poner sus dones al servicio de otros.
          </p>
        </article>
        <article data-animate="card" class="rounded-3xl border border-gray-200 bg-gray-50 p-6 sm:p-8">
          <p class="text-primary text-xs uppercase tracking-[0.2em] font-semibold">Alcance</p>
          <h2 class="font-display text-3xl text-charcoal mt-4">Cerca y lejos.</h2>
          <p class="text-gray-600 text-sm mt-4 leading-relaxed">
            La visión alcanza barrios, provincias y naciones. Donde Dios abre una puerta, buscamos responder con obediencia y amor.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section data-animate="reveal" class="pb-14 md:pb-16 bg-white">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
      <div class="mb-8 md:mb-10">
        <span class="text-primary text-xs uppercase tracking-[0.22em] font-semibold">Lugares</span>
        <h2 class="font-display text-3xl sm:text-4xl text-charcoal mt-2">Destinos misioneros</h2>
      </div>
      <div class="divide-y divide-gray-200 border-y border-gray-200">
        {
          missionsChronological.map((mission) => (
            <article
              data-animate="card"
              class="mission-card grid grid-cols-1 gap-6 py-8 md:grid-cols-[0.68fr_1.32fr] md:gap-10 md:py-10"
            >
              <div>
                <div class="mb-3 flex flex-wrap items-center gap-2">
                  <span class="inline-flex rounded-full bg-gray-100 px-3 py-1 text-[10px] uppercase tracking-[0.2em] text-charcoal font-semibold">
                    {dateFormatter.format(getLocalMissionDate(mission.startDate))}
                  </span>
                </div>
                <p class="text-[11px] uppercase tracking-[0.18em] text-gray-500">{mission.country}</p>
                <h3 class="font-display text-4xl text-charcoal mt-2">{mission.place}</h3>
                <p class="mt-5 text-gray-600 text-base leading-relaxed">{mission.summary}</p>
                <p class="mt-4 text-sm leading-relaxed text-gray-600">
                  En este destino enfocamos los esfuerzos en {mission.focus.toLowerCase()}, acompañando lo que Dios ya está haciendo y fortaleciendo el trabajo local.
                </p>
                <p class="mt-5 text-xs uppercase tracking-[0.18em] text-charcoal">{mission.focus}</p>
              </div>
              <div>
                <div class="overflow-hidden rounded-2xl bg-charcoal">
                  {
                    mission.video ? (
                      <video
                        class="mission-video aspect-video w-full object-cover"
                        data-src={mission.video}
                        poster={mission.image}
                        muted
                        loop
                        playsinline
                        preload="none"
                        aria-label={`Video mision ${mission.place}`}
                      />
                    ) : (
                      <img src={mission.image} alt={`Mision ${mission.place}`} class="aspect-video w-full object-cover" />
                    )
                  }
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />

  <script>
    const missionVideos = [...document.querySelectorAll('.mission-video')];
    const videoStates = new WeakMap();
    let pointerPosition = null;

    const loadMissionVideo = (video) => {
      if (!video.dataset.src || video.dataset.loaded === 'true') return;

      const source = document.createElement('source');
      source.src = video.dataset.src;
      source.type = 'video/mp4';
      video.append(source);
      video.dataset.loaded = 'true';
      video.load();
    };

    const playMissionVideo = (video) => {
      loadMissionVideo(video);
      video.play().catch(() => {});
    };

    const pauseMissionVideo = (video) => {
      video.pause();
    };

    const updateMissionVideo = (video) => {
      const state = videoStates.get(video);
      if (!state) return;

      if (state.hovered || state.focused || state.pinned) {
        playMissionVideo(video);
        return;
      }

      pauseMissionVideo(video);
    };

    const refreshHoverFromPointer = () => {
      if (!pointerPosition) return;

      const hoveredElement = document.elementFromPoint(pointerPosition.x, pointerPosition.y);
      missionVideos.forEach((video) => {
        const state = videoStates.get(video);
        if (!state) return;

        state.hovered = hoveredElement ? state.card.contains(hoveredElement) : false;
        updateMissionVideo(video);
      });
    };

    missionVideos.forEach((video) => {
      const card = video.closest('.mission-card');
      if (!card) return;
      videoStates.set(video, { card, hovered: false, focused: false, pinned: false });

      card.addEventListener('mouseenter', () => {
        videoStates.get(video).hovered = true;
        updateMissionVideo(video);
      });
      card.addEventListener('mouseleave', () => {
        videoStates.get(video).hovered = false;
        updateMissionVideo(video);
      });
      card.addEventListener('focusin', () => {
        videoStates.get(video).focused = true;
        updateMissionVideo(video);
      });
      card.addEventListener('focusout', () => {
        videoStates.get(video).focused = false;
        updateMissionVideo(video);
      });
    });

    window.addEventListener(
      'pointermove',
      (event) => {
        pointerPosition = { x: event.clientX, y: event.clientY };
      },
      { passive: true }
    );
    window.addEventListener('scroll', refreshHoverFromPointer, { passive: true });

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const video = entry.target.querySelector('.mission-video');
            if (!video) return;
            const state = videoStates.get(video);
            if (!state) return;

            state.pinned = entry.isIntersecting && entry.intersectionRatio >= 0.72;
            updateMissionVideo(video);
          });
        },
        { threshold: [0, 0.72] }
      );

      document.querySelectorAll('.mission-card').forEach((card) => observer.observe(card));
    }
  </script>
</BaseLayout>
